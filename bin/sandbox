# See PRINCIPLES.md for the design intent (threat model, tier model,
# credential isolation, default-deny egress, filesystem masking).
set -euo pipefail

###############################################################################
# Constants & paths
###############################################################################
SANDBOX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Version identity is resolved ONCE at build/release/install time by
# scripts/stamp-version.sh and embedded in ${SANDBOX_ROOT}/.version — the
# runtime only READS it, never invoking git (whose `describe` output depends on
# which tags a clone happens to have fetched, so two clones of the same commit
# could disagree). A checkout that has never been installed has no .version and
# honestly reports "dev". Parsed (not sourced) so a malformed file can't execute.
SANDBOX_VERSION="dev"
SANDBOX_COMMIT=""
SANDBOX_COMMIT_DATE=""
SANDBOX_BUILD_DATE=""
SANDBOX_TREE_STATE=""
if [[ -f "${SANDBOX_ROOT}/.version" ]]; then
  while IFS='=' read -r _vkey _vval; do
    case "${_vkey}" in
      VERSION)     SANDBOX_VERSION="${_vval}" ;;
      COMMIT)      SANDBOX_COMMIT="${_vval}" ;;
      COMMIT_DATE) SANDBOX_COMMIT_DATE="${_vval}" ;;
      BUILD_DATE)  SANDBOX_BUILD_DATE="${_vval}" ;;
      TREE_STATE)  SANDBOX_TREE_STATE="${_vval}" ;;
    esac
  done < "${SANDBOX_ROOT}/.version"
  unset _vkey _vval
fi
SANDBOX_LOGS_DIR="${SANDBOX_LOGS_DIR:-${HOME}/.sandbox/logs}"
SANDBOX_NAMESPACE="sandbox"
SANDBOX_RUNTIME_CLASS="gvisor"
SANDBOX_SERVICE_ACCOUNT="sandbox-agent"

# Source library files
# shellcheck source=../lib/platform.sh
source "${SANDBOX_ROOT}/lib/platform.sh"
# shellcheck source=../lib/lima.sh
source "${SANDBOX_ROOT}/lib/lima.sh"
# shellcheck source=../lib/cluster.sh
source "${SANDBOX_ROOT}/lib/cluster.sh"
# shellcheck source=../lib/agents.sh
source "${SANDBOX_ROOT}/lib/agents.sh"
# shellcheck source=../lib/tier.sh
source "${SANDBOX_ROOT}/lib/tier.sh"
# shellcheck source=../lib/policy.sh
source "${SANDBOX_ROOT}/lib/policy.sh"
# shellcheck source=../lib/resources.sh
source "${SANDBOX_ROOT}/lib/resources.sh"
# shellcheck source=../lib/manifest.sh
source "${SANDBOX_ROOT}/lib/manifest.sh"
# shellcheck source=../lib/filesystem.sh
source "${SANDBOX_ROOT}/lib/filesystem.sh"
# shellcheck source=../lib/credentials.sh
source "${SANDBOX_ROOT}/lib/credentials.sh"
# shellcheck source=../lib/audit.sh
source "${SANDBOX_ROOT}/lib/audit.sh"
# shellcheck source=../lib/checks.sh
source "${SANDBOX_ROOT}/lib/checks.sh"
# shellcheck source=../lib/config.sh
source "${SANDBOX_ROOT}/lib/config.sh"
# shellcheck source=../lib/profile.sh
source "${SANDBOX_ROOT}/lib/profile.sh"
# shellcheck source=../lib/vetting.sh
source "${SANDBOX_ROOT}/lib/vetting.sh"

source "${SANDBOX_ROOT}/lib/catalogue.sh"

source "${SANDBOX_ROOT}/lib/dependency.sh"
# shellcheck source=../lib/onboard.sh
source "${SANDBOX_ROOT}/lib/onboard.sh"
# shellcheck source=../lib/secrets.sh
source "${SANDBOX_ROOT}/lib/secrets.sh"
# shellcheck source=../lib/network.sh
source "${SANDBOX_ROOT}/lib/network.sh"
# shellcheck source=lib/dns.sh
source "${SANDBOX_ROOT}/lib/dns.sh"
# shellcheck source=../lib/certs.sh
source "${SANDBOX_ROOT}/lib/certs.sh"
# shellcheck source=../lib/link.sh
source "${SANDBOX_ROOT}/lib/link.sh"

# Pinned infra component versions (k3s/Cilium/gVisor/helm/nerdctl). Pure variable
# defaults, no side effects — used by `status` (pinned-vs-installed) and `upgrade`.
# shellcheck source=../setup/versions.sh
source "${SANDBOX_ROOT}/setup/versions.sh"
# Where setup/upgrade record what the cluster was provisioned with.
SANDBOX_INFRA_VERSIONS_FILE="${SANDBOX_INFRA_VERSIONS_FILE:-${HOME}/.sandbox/infra-versions}"

###############################################################################
# Utility helpers
###############################################################################

# Color output — enabled only when stdout is a TTY and NO_COLOR is unset
# (https://no-color.org/). When piped, redirected, or captured in logs the
# variables are empty, so output stays plain and grep-friendly. die()/warn()
# gate on stderr (fd 2) independently, since stdout and stderr can be
# redirected separately.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RESET=$'\033[0m'
else
  C_RED=''; C_GREEN=''; C_YELLOW=''; C_RESET=''
fi
if [[ -t 2 && -z "${NO_COLOR:-}" ]]; then
  C_RED_ERR=$'\033[31m'; C_YELLOW_ERR=$'\033[33m'; C_RESET_ERR=$'\033[0m'
else
  C_RED_ERR=''; C_YELLOW_ERR=''; C_RESET_ERR=''
fi

# Paint a status word for stdout. Used by cmd_status and friends so the
# health verb (running / configured / not found) stands out at a glance.
c_ok()   { printf '%s%s%s' "${C_GREEN}"  "$*" "${C_RESET}"; }
c_warn() { printf '%s%s%s' "${C_YELLOW}" "$*" "${C_RESET}"; }
c_err()  { printf '%s%s%s' "${C_RED}"    "$*" "${C_RESET}"; }

die() {
  echo "${C_RED_ERR}ERROR:${C_RESET_ERR} $*" >&2
  exit 1
}

info() {
  echo "  $*"
}

warn() {
  echo "${C_YELLOW_ERR}WARN:${C_RESET_ERR} $*" >&2
}

# Print usage and exit
usage() {
  cat <<EOF
sandbox ${SANDBOX_VERSION} — AI agent sandboxed execution environment

USAGE:
  sandbox <COMMAND> [OPTIONS]

COMMANDS:
  run          Launch a sandboxed agent session
  resume       Reconnect to a running session
  allow        Add domains to a running session's egress allowlist (no restart)
  list         List active and recent sessions
  logs         Show audit log for a session
  flows        Show Hubble network flows for a session
  stop         Stop a session and run teardown
  cleanup      Remove old session logs
  check        Pre-flight workspace check
  status       Show cluster and sandbox status (incl. infra versions vs pins)
  install      Install/configure sandbox prerequisites (cluster, CNI, gVisor)
  uninstall    Tear down the sandbox cluster and host artifacts
  upgrade      Update the CLI to the latest release (--infra: k3s/Cilium/gVisor/betterleaks)
  setup        Alias of 'install' (retained for compatibility)
  onboard      Stage host-side agent OAuth state for first-run convenience
  secret       Manage host-side secret store (injected per-session by profile)
  mask         Manage per-repo file masking (add/list masked_paths)
  exceptions   Record reviewed false positives for the secret gate (add/list)
  vet          Attest a repo as cleared for agent use (signed tag; see run gate)
  profile      Create and manage launch profiles (save/list/show/delete)
  link         Link a git-backed team overlay and keep it pinned (status/sync/unlink)
  configure-network   Re-detect host network state and reconcile k3s/Cilium
                      and CoreDNS split-horizon DNS (run after a VPN reconnects
                      or the host IP changes; --show-dns previews the DNS plan)
  setup-proxy-cert    Extract a corporate TLS-intercept proxy's root CA
                      from the host trust store and drop it in
                      config/extra-ca-certs/ for the image build
  rebuild      Rebuild sandbox container image(s)
  version      Print version

Run 'sandbox <COMMAND> --help' for command-specific help.

EXAMPLES:
  sandbox run --agent claude --tier 1
  sandbox run --agent claude --tier 2 --repo ~/repos/my-project
  sandbox run --agent claude --tier 3 --repo ~/repos/infra \\
      --infra-kubeconfig ~/.kube/config --infra-kube-context dev
  sandbox run --agent opencode --tier 3 --repo ~/repos/infra --infra-token ~/.infra-token
  sandbox profile save --tier 2 --agent codex --repo ~/git/public/stratum --name stratum-codex
  sandbox run --profile stratum-codex
  sandbox list
  sandbox logs ses-20260401-143022-a7b3
  sandbox cleanup --older-than 30
EOF
  exit 0
}

usage_run() {
  cat <<EOF
sandbox run — Launch a sandboxed agent session

USAGE:
  sandbox run [OPTIONS]

OPTIONS:
  --agent <claude|codex|opencode|copilot|grok>   Agent to run (default: claude)
  --tier <1|2|3>                    Isolation tier (default: 1)
  --profile <NAME>                  Named profile or numeric tier alias.
                                    '1', '2', '3' aliases --tier <N>.
                                    Other names resolve a YAML in
                                    ~/.sandbox/profiles/<name>.yaml or the
                                    overlay's profiles/<name>.yaml and
                                    contribute: required tier, optional
                                    default --repo, and extra_allowed_domains
                                    (subject to the blocked-destinations
                                    check). Mutually consistent with --tier.
  --repo <PATH>                     Workspace path (required for tier 2/3;
                                    repeatable — pass multiple times to mount
                                    several repos under /workspace/<basename>)
  --allow-domain <DOMAIN>           Extra allowed egress domain (repeatable)
  --base-url <URL>                  OpenAI-compatible endpoint URL for the
                                    opencode agent. Overrides OPENCODE_BASE_URL
                                    in the host env. Required for opencode
                                    (via this flag or the env var).
  --infra-token <PATH>              Path to infra token file (tier 3)
                                    Injected as INFRA_TOKEN env var inside pod.
  --infra-kubeconfig <PATH>         Path to kubeconfig file (tier 3)
                                    Minified to a single context, mounted as a
                                    Secret at /home/agent/.kube/config, and
                                    KUBECONFIG is set. The cluster's API
                                    server hostname/port is auto-allowlisted.
  --infra-kube-context <NAME>       Context to extract from --infra-kubeconfig
                                    (default: kubeconfig's current-context)
  --allow-exec-plugin               Don't prompt when --infra-kubeconfig uses
                                    an exec credential plugin (it won't work
                                    in the pod; useful only if kubectl access
                                    is best-effort, e.g. you also pass an
                                    --infra-token for the real auth path)
  --infra-endpoint <URL>            Extra infra endpoint URL (tier 3, repeatable)
  --dry-run                         Print manifests without applying
  --name <NAME>                     Human-readable session name
  --keep-alive                      Leave the pod running after disconnect
                                    (default: tear down on exit to free cluster
                                    resources; conversation history persists in
                                    ~/.sandbox/agent-home/<agent>/ and can be
                                    restored via the agent's /resume command)
  --i-accept-unmasked-secrets       Launch even if betterleaks finds a secret
                                    in a workspace file the mask won't hide.
                                    The findings are printed; the agent WILL
                                    be able to read them. Without this flag
                                    such a finding aborts the launch.
  --i-accept-unvetted-repo          Launch even when 'vetting: required' and a
                                    --repo has no verified attestation at HEAD.
                                    The unvetted repo(s) are printed and the
                                    acceptance is recorded in the audit log.
  --help                            Show this help

TIERS:
  1  Ephemeral workspace, agent domains only
  2  Host repo mounted, agent + project domains (github, pypi, npm, terraform)
  3  Tier 2 + infra tooling image + dynamic endpoints
     Requires at least one of --infra-token or --infra-kubeconfig.

PERSISTENT EXTRAS:
  Three sources contribute additional allowed egress domains on every run,
  so you don't need --allow-domain for hosts your team always needs:
    ~/.sandbox/config.yaml         extra_allowed_domains: list (YAML)
    \$SANDBOX_EXTRA_ALLOWED_DOMAINS comma-separated env var
    <repo>/.sandbox/config.yaml    per-repo extras (one per --repo)
  All three are subject to the blocked-destinations check.

SECRET GATE (tier 2/3):
  Before launch, each --repo is scanned with betterleaks. A secret in a
  file the mask would NOT hide aborts the launch with the offending path(s)
  and a 'sandbox mask add' command to mask them. betterleaks is required;
  its absence fails the launch closed. Override with
  --i-accept-unmasked-secrets. See 'sandbox mask --help'.

VETTING GATE (tier 2/3):
  Each --repo is checked for a signed attestation that a trusted reviewer
  cleared its current HEAD for agent use. Posture is operator-controlled via
  'vetting:' in ~/.sandbox/config.yaml (an overlay may ratchet it up):
    off       no gate.
    advisory  print status and proceed (default).
    required  refuse launch unless every --repo carries a verified attestation
              at HEAD; override with --i-accept-unvetted-repo.
  Attest a repo with 'sandbox vet --repo <PATH>'. See 'sandbox vet --help'.

OVERLAYS:
  Teams can ship a directory of profiles, GOVERNANCE.md, an additive
  blocked-destinations.yaml, and extra-ca-certs/ in an overlay. Point at
  it via \$SANDBOX_OVERLAY or 'overlay: <path>' in ~/.sandbox/config.yaml.
  Overlays only ADD restrictions — nothing in an overlay can weaken the
  org-level blocked-destinations list or the tier model.

See PRINCIPLES.md for design intent (threat model, tier model, credential
isolation, never-permitted list).
EOF
  exit 0
}

###############################################################################
# Session ID generation — ses-<YYYYMMDD>-<HHMMSS>-<4hex>
###############################################################################
generate_session_id() {
  local date_part
  local time_part
  local rand_part
  date_part="$(date -u '+%Y%m%d')"
  time_part="$(date -u '+%H%M%S')"
  rand_part="$(head -c 2 /dev/urandom | xxd -p | head -c 4)"
  echo "ses-${date_part}-${time_part}-${rand_part}"
}

###############################################################################
# generate_uuid — emit a random RFC-4122 v4 UUID using only /dev/urandom and
# xxd (both already required tools — see lib/checks.sh; avoids a uuidgen dep).
# Used to pin an agent's conversation ID so its transcript file is known.
###############################################################################
generate_uuid() {
  local h
  h="$(head -c 16 /dev/urandom | xxd -p | tr -d '\n')"
  printf '%s-%s-4%s-%x%s-%s\n' \
    "${h:0:8}" "${h:8:4}" "${h:13:3}" \
    "$(( 0x${h:16:1} & 0x3 | 0x8 ))" "${h:17:3}" "${h:20:12}"
}

###############################################################################
# resolve_pod_name — read pod_name from session.json; fall back to legacy format
###############################################################################
resolve_pod_name() {
  local session_id="$1"
  local session_json="${SANDBOX_LOGS_DIR}/${session_id}/session.json"
  local pod_name
  pod_name="$(jq -r '.pod_name // ""' "${session_json}" 2>/dev/null || true)"
  if [[ -z "${pod_name}" ]]; then
    pod_name="sandbox-${session_id}"
  fi
  echo "${pod_name}"
}

###############################################################################
# Session banner
###############################################################################
print_session_banner() {
  local session_id="$1"
  local agent="$2"
  local tier="$3"
  local domain_count="$4"
  local log_dir="$5"
  local name="${6:-}"
  shift 6
  local -a repos=("$@")

  local agent_desc
  local tier_desc

  case "${agent}" in
    claude)   agent_desc="claude (Anthropic OAuth)" ;;
    codex)    agent_desc="codex (OpenAI OAuth)" ;;
    opencode) agent_desc="opencode (vLLM proxy)" ;;
    copilot)  agent_desc="copilot (GitHub OAuth)" ;;
    grok)     agent_desc="grok (xAI OAuth)" ;;
    *)        agent_desc="${agent}" ;;
  esac

  case "${tier}" in
    1) tier_desc="1 — Ephemeral" ;;
    2) tier_desc="2 — Project" ;;
    3) tier_desc="3 — Infra" ;;
    *) tier_desc="${tier}" ;;
  esac

  local log_display="${log_dir/#${HOME}/\~}"
  local sep="  ────────────────────────────────────────────────"

  echo "${sep}"
  echo "  SANDBOX SESSION"
  echo "${sep}"
  printf "  %-9s  %s\n" "Session" "${session_id}"
  [[ -n "${name}" ]] && printf "  %-9s  %s\n" "Name" "${name}"
  printf "  %-9s  %s\n" "Agent"   "${agent_desc}"
  printf "  %-9s  %s\n" "Tier"    "${tier_desc}"
  # Read profile/overlay from env vars set by cmd_run — avoids threading
  # two more positional args through every banner call site.
  if [[ -n "${SESSION_PROFILE:-}" ]]; then
    printf "  %-9s  %s\n" "Profile" "${SESSION_PROFILE}"
  fi
  if [[ -n "${SESSION_OVERLAY:-}" ]]; then
    printf "  %-9s  %s\n" "Overlay" "${SESSION_OVERLAY/#${HOME}/\~}"
  fi

  if [[ "${#repos[@]}" -eq 0 ]]; then
    printf "  %-9s  %s\n" "Repo"  "emptyDir (ephemeral)"
  elif [[ "${#repos[@]}" -eq 1 ]]; then
    printf "  %-9s  %s\n" "Repo"  "${repos[0]/#${HOME}/\~}"
  else
    printf "  %-9s  %s\n" "Repos"  "${#repos[@]} mounted under /workspace:"
    local r
    for r in "${repos[@]}"; do
      printf "             /workspace/%s  ←  %s\n" \
        "$(basename "${r}")" "${r/#${HOME}/\~}"
    done
  fi

  printf "  %-9s  %s\n" "Egress"  "${agent} + tier${tier} (${domain_count} domains)"
  printf "  %-9s  %s\n" "Runtime" "gvisor"
  printf "  %-9s  %s\n" "Log"     "${log_display}"
  echo "${sep}"
}

###############################################################################
# cmd_run — main session launch
###############################################################################
cmd_run() {
  local opt_agent="claude"
  local opt_agent_explicit="false"
  local opt_tier="1"
  local opt_tier_explicit="false"
  local opt_profile=""
  local -a opt_repos=()
  local opt_name=""
  local opt_infra_token=""
  local opt_infra_kubeconfig=""
  local opt_infra_kube_context=""
  local opt_allow_exec_plugin="false"
  local opt_dry_run="false"
  local opt_keep_alive="false"
  local opt_accept_unmasked_secrets="false"
  local opt_accept_unvetted_repo="false"
  local opt_base_url=""
  local -a opt_allow_domains=()
  local -a opt_infra_endpoints=()

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)               usage_run ;;
      --agent)                 opt_agent="${2:?--agent requires a value}"; opt_agent_explicit="true"; shift ;;
      --agent=*)               opt_agent="${1#--agent=}"; opt_agent_explicit="true" ;;
      --tier)                  opt_tier="${2:?--tier requires a value}"; opt_tier_explicit="true"; shift ;;
      --tier=*)                opt_tier="${1#--tier=}"; opt_tier_explicit="true" ;;
      --profile)               opt_profile="${2:?--profile requires a value}"; shift ;;
      --profile=*)             opt_profile="${1#--profile=}" ;;
      --repo)                  opt_repos+=("${2:?--repo requires a value}"); shift ;;
      --repo=*)                opt_repos+=("${1#--repo=}") ;;
      --allow-domain)          opt_allow_domains+=("${2:?--allow-domain requires a value}"); shift ;;
      --allow-domain=*)        opt_allow_domains+=("${1#--allow-domain=}") ;;
      --base-url)              opt_base_url="${2:?--base-url requires a value}"; shift ;;
      --base-url=*)            opt_base_url="${1#--base-url=}" ;;
      --infra-token)           opt_infra_token="${2:?--infra-token requires a value}"; shift ;;
      --infra-token=*)         opt_infra_token="${1#--infra-token=}" ;;
      --infra-kubeconfig)      opt_infra_kubeconfig="${2:?--infra-kubeconfig requires a value}"; shift ;;
      --infra-kubeconfig=*)    opt_infra_kubeconfig="${1#--infra-kubeconfig=}" ;;
      --infra-kube-context)    opt_infra_kube_context="${2:?--infra-kube-context requires a value}"; shift ;;
      --infra-kube-context=*)  opt_infra_kube_context="${1#--infra-kube-context=}" ;;
      --allow-exec-plugin)     opt_allow_exec_plugin="true" ;;
      --infra-endpoint)        opt_infra_endpoints+=("${2:?--infra-endpoint requires a value}"); shift ;;
      --infra-endpoint=*)      opt_infra_endpoints+=("${1#--infra-endpoint=}") ;;
      --dry-run)               opt_dry_run="true" ;;
      --name)                  opt_name="${2:?--name requires a value}"; shift ;;
      --name=*)                opt_name="${1#--name=}" ;;
      --keep-alive)            opt_keep_alive="true" ;;
      --i-accept-unmasked-secrets) opt_accept_unmasked_secrets="true" ;;
      --i-accept-unvetted-repo) opt_accept_unvetted_repo="true" ;;
      *)                       die "Unknown option: $1. Run 'sandbox run --help' for usage." ;;
    esac
    shift
  done

  # Expand tilde in repo / kubeconfig paths
  local _i
  for _i in "${!opt_repos[@]}"; do
    opt_repos[$_i]="${opt_repos[$_i]/#\~/${HOME}}"
  done
  if [[ -n "${opt_infra_kubeconfig}" ]]; then
    opt_infra_kubeconfig="${opt_infra_kubeconfig/#\~/${HOME}}"
  fi

  # If a git-linked team overlay is configured, do a cached, rate-limited
  # fetch and hint (once, to stderr) when it's behind its pinned ref. This is
  # notify-only: it never mutates the overlay mid-launch. Skipped entirely by
  # SANDBOX_NO_LINK_CHECK=1 and non-fatal on any failure.
  link_notify_if_behind || true

  # Profile resolution. Numeric profiles ('1'|'2'|'3') are pure aliases for
  # --tier <N>. Named profiles resolve to a YAML in ~/.sandbox/profiles or
  # the overlay; their `tier:` field is treated exactly like --tier and
  # passes through the same validate_tier check below. SESSION_PROFILE /
  # SESSION_OVERLAY are exported for the audit record so we can tell, post
  # hoc, which profile/overlay produced the session.
  SESSION_PROFILE=""
  SESSION_OVERLAY=""
  if [[ -n "${opt_profile}" ]]; then
    local _resolved_overlay
    _resolved_overlay="$(resolve_overlay_path)"
    SESSION_OVERLAY="${_resolved_overlay}"

    if is_numeric_profile "${opt_profile}"; then
      if [[ "${opt_tier_explicit}" == "true" ]] && [[ "${opt_tier}" != "${opt_profile}" ]]; then
        die "--profile ${opt_profile} conflicts with --tier ${opt_tier}; pass only one."
      fi
      opt_tier="${opt_profile}"
      SESSION_PROFILE="${opt_profile}"
    else
      local _profile_path
      if ! _profile_path="$(find_profile_path "${opt_profile}")"; then
        die "Profile '${opt_profile}' not found in ~/.sandbox/profiles/ or overlay (\$SANDBOX_OVERLAY / ~/.sandbox/config.yaml overlay:)."
      fi
      SESSION_PROFILE="${opt_profile}"
      echo "==> Loading profile '${opt_profile}' (${_profile_path/#${HOME}/\~})"

      local _profile_tier
      _profile_tier="$(extract_yaml_scalar_from_file "${_profile_path}" tier)"
      [[ -n "${_profile_tier}" ]] || die "Profile '${opt_profile}' missing required 'tier:' field."
      if [[ "${opt_tier_explicit}" == "true" ]] && [[ "${opt_tier}" != "${_profile_tier}" ]]; then
        die "Profile '${opt_profile}' declares tier ${_profile_tier} but --tier ${opt_tier} was also passed; remove --tier or change the profile."
      fi
      opt_tier="${_profile_tier}"

      # agent is optional in a profile. When present it fills in for an
      # absent --agent, mirroring default_repo. An explicit --agent that
      # disagrees is a hard error (same stance as the tier check above), so
      # there's never ambiguity about which agent a launch used.
      local _profile_agent
      _profile_agent="$(extract_yaml_scalar_from_file "${_profile_path}" agent)"
      if [[ -n "${_profile_agent}" ]]; then
        if [[ "${opt_agent_explicit}" == "true" ]] && [[ "${opt_agent}" != "${_profile_agent}" ]]; then
          die "Profile '${opt_profile}' declares agent '${_profile_agent}' but --agent '${opt_agent}' was also passed; remove --agent or change the profile."
        fi
        opt_agent="${_profile_agent}"
        echo "    agent: ${_profile_agent}"
      fi

      local _profile_default_repo
      _profile_default_repo="$(extract_yaml_scalar_from_file "${_profile_path}" default_repo)"
      if [[ -n "${_profile_default_repo}" ]] && [[ "${#opt_repos[@]}" -eq 0 ]]; then
        opt_repos+=("${_profile_default_repo/#\~/${HOME}}")
        echo "    default_repo: ${_profile_default_repo}"
      fi

      local _profile_extra
      while IFS= read -r _profile_extra; do
        [[ -z "${_profile_extra}" ]] && continue
        opt_allow_domains+=("${_profile_extra}")
      done < <(extract_yaml_list_from_file "${_profile_path}" extra_allowed_domains)

      # Phase 4: secrets are read here so the audit record can see them.
      # Phase 5: mcps + services are the per-session dependency declarations,
      # resolved against the catalogue after the session ID is known (Step 3b).
      SESSION_PROFILE_SECRETS="$(extract_yaml_list_from_file "${_profile_path}" secrets | paste -sd, - 2>/dev/null || true)"
      SESSION_PROFILE_MCPS="$(extract_yaml_list_from_file "${_profile_path}" mcps | paste -sd, - 2>/dev/null || true)"
      SESSION_PROFILE_SERVICES="$(extract_yaml_list_from_file "${_profile_path}" services | paste -sd, - 2>/dev/null || true)"
    fi
  fi

  ###########################################################################
  # Step 1: Validate inputs
  ###########################################################################
  echo "==> Validating inputs..."

  validate_agent "${opt_agent}"
  validate_tier "${opt_tier}"

  # --base-url overrides OPENCODE_BASE_URL from the host environment. Exported
  # so the downstream libs (credentials.sh, manifest.sh, agents.sh) see the
  # resolved value through the same env-var path they always use.
  if [[ -n "${opt_base_url}" ]]; then
    export OPENCODE_BASE_URL="${opt_base_url}"
  fi

  # opencode requires both an API key and an endpoint URL — fail fast before
  # creating any cluster resources. The URL must include a scheme; without it,
  # the host-side curl that fetches the model list silently produces an empty
  # config and the launched pod ends up reporting "no provider set".
  if [[ "${opt_agent}" == "opencode" ]]; then
    if [[ -z "${OPENCODE_API_KEY:-}" ]]; then
      die "OPENCODE_API_KEY must be set in host environment for opencode agent."
    fi
    if [[ -z "${OPENCODE_BASE_URL:-}" ]]; then
      die "opencode requires an OpenAI-compatible endpoint URL — pass --base-url <URL> or set OPENCODE_BASE_URL in the host environment."
    fi
    if [[ ! "${OPENCODE_BASE_URL}" =~ ^https?://[^/[:space:]] ]]; then
      die "OPENCODE_BASE_URL must be a complete URL with http(s) scheme — got '${OPENCODE_BASE_URL}'. Example: https://vllm-proxy.example.com/v1"
    fi
  fi

  if [[ "${opt_tier}" -ge 2 ]] && [[ "${#opt_repos[@]}" -eq 0 ]]; then
    die "Tier ${opt_tier} requires --repo <PATH>."
  fi

  local _r
  for _r in "${opt_repos[@]+"${opt_repos[@]}"}"; do
    validate_repo_path "${_r}"
  done

  # When multiple --repo are given, basenames must be unique because each
  # repo is mounted at /workspace/<basename>. Refuse on collision.
  if [[ "${#opt_repos[@]}" -gt 1 ]]; then
    local _dup
    _dup="$(printf '%s\n' "${opt_repos[@]}" | xargs -n1 basename 2>/dev/null \
      | sort | uniq -d | head -1)"
    if [[ -n "${_dup}" ]]; then
      die "duplicate --repo basename '${_dup}' — rename one repo or symlink it before passing both."
    fi
  fi

  if [[ "${opt_tier}" -eq 3 ]]; then
    if [[ -z "${opt_infra_token}" ]] && [[ -z "${opt_infra_kubeconfig}" ]]; then
      die "Tier 3 requires at least one of --infra-token <PATH> or --infra-kubeconfig <PATH>."
    fi
    if [[ -n "${opt_infra_token}" ]] && [[ ! -f "${opt_infra_token}" ]]; then
      die "Infra token file not found: ${opt_infra_token}."
    fi
    if [[ -n "${opt_infra_kubeconfig}" ]] && [[ ! -f "${opt_infra_kubeconfig}" ]]; then
      die "Kubeconfig file not found: ${opt_infra_kubeconfig}."
    fi
  else
    if [[ -n "${opt_infra_kubeconfig}" ]]; then
      die "--infra-kubeconfig is only valid for tier 3."
    fi
  fi
  if [[ -n "${opt_infra_kube_context}" ]] && [[ -z "${opt_infra_kubeconfig}" ]]; then
    die "--infra-kube-context requires --infra-kubeconfig."
  fi

  # Merge persistent extras from ~/.sandbox/config.yaml and the
  # SANDBOX_EXTRA_ALLOWED_DOMAINS env var into the per-invocation list so
  # they go through the same blocked-destinations validation below. Lets
  # operators ship a per-user/per-team default allowlist without baking
  # their internal hosts into this repo. See lib/config.sh.
  local _extra_domain
  while IFS= read -r _extra_domain; do
    [[ -z "${_extra_domain}" ]] && continue
    opt_allow_domains+=("${_extra_domain}")
  done < <(load_user_extra_allowed_domains)

  # Per-repo extras: load <repo>/.sandbox/config.yaml for each --repo and
  # print a banner showing what each repo contributed. Banner runs on every
  # session start (not just first-time) so a domain slipped into a repo
  # config stays visible to the operator launching it. Each entry still
  # goes through the blocked-destinations check below.
  local _repo _repo_config _d
  local -a _repo_extras=()
  for _repo in "${opt_repos[@]+"${opt_repos[@]}"}"; do
    _repo_config="${_repo}/.sandbox/config.yaml"
    [[ -f "${_repo_config}" ]] || continue
    _repo_extras=()
    while IFS= read -r _extra_domain; do
      [[ -z "${_extra_domain}" ]] && continue
      _repo_extras+=("${_extra_domain}")
      opt_allow_domains+=("${_extra_domain}")
    done < <(load_extra_allowed_domains_from_file "${_repo_config}")
    if [[ "${#_repo_extras[@]}" -gt 0 ]]; then
      echo "==> $(basename "${_repo}")/.sandbox/config.yaml contributes ${#_repo_extras[@]} extra domain(s):"
      for _d in "${_repo_extras[@]}"; do
        echo "      - ${_d}"
      done
    fi
  done

  # Validate allowed domains against the block list. check_egress_target_not_blocked
  # also runs the blocked-CIDR membership check when an entry is an IP literal,
  # so an --allow-domain'd IP can't slip past the (domain-only) name match.
  for domain in "${opt_allow_domains[@]+"${opt_allow_domains[@]}"}"; do
    check_egress_target_not_blocked "${domain}"
  done

  # --infra-endpoint URLs are handed straight to the policy builder and never
  # enter opt_allow_domains, so validate their hosts here too — otherwise a
  # blocked (or accidentally-production) endpoint bypasses the block list
  # entirely. Known at parse time, so this still fails fast before any cluster ops.
  local _ep _ep_host
  for _ep in "${opt_infra_endpoints[@]+"${opt_infra_endpoints[@]}"}"; do
    _ep_host="$(url_host "${_ep}")"
    [[ -z "${_ep_host}" ]] && continue
    check_egress_target_not_blocked "${_ep_host}"
  done

  # Fail fast on a malformed blocked_cidrs entry, before any cluster ops —
  # a bad CIDR would otherwise render into the egressDeny rule and Cilium
  # would reject the whole policy (a block that silently doesn't block).
  check_blocked_cidrs_valid

  # Profile-declared secrets: parse SESSION_PROFILE_SECRETS (set by the
  # profile-resolution block above), confirm each name exists in the
  # host-side store, and surface them for the manifest builder. The
  # actual K8s Secret is created later (Step 4 area) once we know the
  # session ID. Validating up front fails fast before any cluster ops.
  # Global array; plain assignment avoids `declare -g` (bash 4.2+) for macOS
  # bash 3.2 compatibility. An un-'local'-ized name resolves to the global.
  SESSION_PROFILE_SECRETS_LIST=()
  SESSION_HAS_SECRETS="false"
  if [[ -n "${SESSION_PROFILE_SECRETS:-}" ]]; then
    local _s _ifs="${IFS}"
    IFS=','
    for _s in ${SESSION_PROFILE_SECRETS}; do
      _s="$(echo "${_s}" | tr -d '[:space:]')"
      [[ -z "${_s}" ]] && continue
      secret_validate_name "${_s}"
      if ! secret_exists "${_s}"; then
        IFS="${_ifs}"
        die "Profile '${SESSION_PROFILE}' requires secret '${_s}' but it's not in the host-side store. Run 'sandbox secret set ${_s}' first."
      fi
      SESSION_PROFILE_SECRETS_LIST+=("${_s}")
    done
    IFS="${_ifs}"
    if [[ "${#SESSION_PROFILE_SECRETS_LIST[@]}" -gt 0 ]]; then
      SESSION_HAS_SECRETS="true"
      echo "==> Profile secrets to inject: ${SESSION_PROFILE_SECRETS_LIST[*]}"
    fi
  fi
  export SESSION_HAS_SECRETS

  # Ensure cluster is reachable (and Lima is running on macOS)
  ensure_cluster_ready

  # Auto-correct Cilium's device wiring if the host's primary NIC or VPN
  # interfaces have changed since the cluster was last configured. Skipped
  # for --dry-run since a correction mutates the cluster (helm upgrade +
  # Cilium restart). See lib/network.sh.
  if [[ "${opt_dry_run}" != "true" ]]; then
    ensure_network_config_current "${SANDBOX_KUBECONFIG}"
  fi

  ###########################################################################
  # Step 1b: Process --infra-kubeconfig (minify, scan for exec plugins,
  #          extract API server host/port). The minified file lives in a
  #          0600 temp file that we delete on exit.
  ###########################################################################
  local kubeconfig_minified=""
  local kube_server_host=""
  local kube_server_port=""
  local kube_server_ip=""
  if [[ -n "${opt_infra_kubeconfig}" ]]; then
    kubeconfig_minified="$(mktemp -t sandbox-kubeconfig.XXXXXX)"
    chmod 0600 "${kubeconfig_minified}"
    # shellcheck disable=SC2064
    trap "rm -f '${kubeconfig_minified}'" EXIT

    echo "==> Minifying kubeconfig (context: ${opt_infra_kube_context:-<current-context>})..."
    minify_kubeconfig "${opt_infra_kubeconfig}" "${opt_infra_kube_context}" \
      > "${kubeconfig_minified}"

    local exec_cmd
    exec_cmd="$(kubeconfig_exec_command "${kubeconfig_minified}")"
    if [[ -n "${exec_cmd}" ]]; then
      warn "kubeconfig uses exec credential plugin '${exec_cmd}'."
      warn "  That binary is NOT present inside the sandbox image, and even if"
      warn "  it were, its host-side config (e.g. ~/.tsh/, ~/.aws/) is not"
      warn "  mounted. Every kubectl call inside the sandbox WILL FAIL at auth."
      warn "  Bake a static kubeconfig before mounting — see examples/ in the"
      warn "  repo, or docs/how-to/tier3-infra-credentials.md."
      if [[ "${opt_allow_exec_plugin}" == "true" ]]; then
        warn "  --allow-exec-plugin set; continuing anyway."
      elif [[ "${opt_dry_run}" == "true" ]]; then
        : # dry-run never launches; no need to prompt
      elif [[ ! -t 0 ]]; then
        die "stdin is not a TTY; refusing to launch with a broken kubeconfig. Pass --allow-exec-plugin to override."
      else
        local reply=""
        printf "  Continue anyway? [y/N] " >&2
        read -r reply
        case "${reply}" in
          y|Y|yes|YES) ;;
          *) die "Aborted. Bake static credentials and retry, or re-run with --allow-exec-plugin." ;;
        esac
      fi
    fi

    local server_url
    server_url="$(kubeconfig_server_url "${kubeconfig_minified}")"
    if [[ -z "${server_url}" ]]; then
      die "Could not read cluster.server from minified kubeconfig."
    fi
    kube_server_host="$(url_host "${server_url}")"
    kube_server_port="$(url_port "${server_url}")"
    echo "  Cluster API: ${server_url}"
    echo "  Auto-allowlisting: ${kube_server_host}:${kube_server_port:-443}"

    # Record the API server hostname in the session allowlist — audit
    # (session.json) and a toFQDNs fallback. Primary enforcement is the
    # toCIDR rule keyed on kube_server_ip (Step 7).
    opt_allow_domains+=("${kube_server_host}")

    # Resolve the API server hostname on the host and pin it as a pod
    # hostAlias. This sidesteps environments where the pod's CoreDNS can't
    # reach the resolver that knows the name (corporate VPN-only DNS, split-
    # horizon DNS, per-link systemd-resolved entries, etc.). Prefer IPv4.
    if [[ "${kube_server_host}" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      # Already a literal IP — no host-side lookup needed.
      kube_server_ip="${kube_server_host}"
    else
      kube_server_ip="$(getent ahostsv4 "${kube_server_host}" 2>/dev/null \
        | awk 'NR==1 {print $1}')"
      if [[ -z "${kube_server_ip}" ]]; then
        warn "Could not resolve ${kube_server_host} on host; pod will rely on"
        warn "  cluster DNS. If the pod fails with 'no such host', resolve the"
        warn "  hostname yourself and add it via your DNS or a hosts entry."
      else
        echo "  Pinning hostAlias: ${kube_server_host} → ${kube_server_ip}"
      fi
    fi

    # Close the auto-allowlist bypass: the API host was appended to
    # opt_allow_domains AFTER the block-validation loop above ran, so it would
    # otherwise never be checked. Validate it now — and the resolved IP too, so
    # a production hostname that resolves into a blocked CIDR is caught even
    # though the name itself matches no blocked_domains pattern. Still fails
    # fast, before any policy/pod/Secret is created (Step 6+).
    check_egress_target_not_blocked "${kube_server_host}"
    if [[ -n "${kube_server_ip}" ]]; then
      check_ip_not_in_blocked_cidrs "${kube_server_ip}"
    fi
  fi

  ###########################################################################
  # Step 2: Pre-session workspace check (Tier 2/3)
  ###########################################################################
  if [[ "${opt_tier}" -ge 2 ]] && [[ "${#opt_repos[@]}" -gt 0 ]]; then
    echo "==> Running pre-session workspace check..."
    for _r in "${opt_repos[@]}"; do
      workspace_prescan "${_r}"
    done
    check_masking_paths "${opt_repos[@]}"
    # Gate the launch on secrets the mask would not hide. Fails closed if
    # betterleaks is absent; --i-accept-unmasked-secrets downgrades the
    # refusal to a printed warning. When this session's model inference
    # endpoint is a trusted internal one (per the overlay's
    # trusted_inference_endpoints list), a would-be block is downgraded to a
    # single interactive confirmation instead — the model-exfil channel is
    # closed, so the operator makes the call. See secret_gate_repos.
    local _endpoint _endpoint_trusted="false"
    _endpoint="$(resolve_inference_endpoint "${opt_agent}")"
    if [[ -n "${_endpoint}" ]] && inference_endpoint_is_trusted "${_endpoint}"; then
      _endpoint_trusted="true"
    fi
    secret_gate_repos "${opt_accept_unmasked_secrets}" "${_endpoint_trusted}" "${opt_repos[@]}"
    # Gate the launch on whether each workspace has been vetted for agent use.
    # Posture (off/advisory/required) is operator-controlled; advisory only
    # prints status, required refuses unless a signed attestation verifies at
    # HEAD. --i-accept-unvetted-repo downgrades a required refusal to a warning.
    vetting_gate_repos "$(resolve_vetting_posture)" "${opt_accept_unvetted_repo}" "${opt_repos[@]}"
  fi

  ###########################################################################
  # Step 3: Generate session ID and auto-name
  ###########################################################################
  local session_id
  session_id="$(generate_session_id)"
  echo "==> Session ID: ${session_id}"

  ###########################################################################
  # Step 3b: Resolve profile-declared dependencies (Phase 5)
  ###########################################################################
  # Resolve mcps:/services: against the catalogue and populate the SESSION_DEP_*
  # globals the policy/manifest/launch paths consume. Cluster-independent and
  # fail-closed: an unknown name, an invalid entry, an MCP for an unsupported
  # agent, or a missing declared secret aborts here, before any object exists.
  resolve_session_dependencies "${session_id}" "${opt_agent}" \
    || die "Dependency resolution failed; aborting launch."
  if [[ "${SESSION_HAS_DEPS:-false}" == "true" ]]; then
    echo "==> Profile dependencies: ${SESSION_DEP_NAMES[*]}"
  fi

  # Auto-generate a human-readable name if not supplied.
  # Single repo → "<repo-basename>/<agent>"; multi-repo → "multi/<agent>";
  # no repo (tier 1) → "<agent>".
  if [[ -z "${opt_name}" ]]; then
    if [[ "${#opt_repos[@]}" -eq 0 ]]; then
      opt_name="${opt_agent}"
    elif [[ "${#opt_repos[@]}" -eq 1 ]]; then
      opt_name="$(basename "${opt_repos[0]}")/${opt_agent}"
    else
      opt_name="multi/${opt_agent}"
    fi
  fi

  # Derive a DNS-safe pod name from the human-readable name + 4hex session suffix.
  # Kubernetes names: lowercase alphanumeric and hyphens only, max 253 chars.
  local short_id="${session_id##*-}"
  local sanitized_name
  sanitized_name="$(echo "${opt_name}" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs 'a-z0-9-' '-' \
    | sed 's/^-*//;s/-*$//')"
  local pod_name="sandbox-${sanitized_name}-${short_id}"

  ###########################################################################
  # Step 4: Create session log directory and write session.json
  ###########################################################################
  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"
  mkdir -p "${log_dir}"

  # Ensure the agent-home directory the pod mounts exists and is writable by the
  # pod's uid 1000 before launch. It is shared across sessions so auth tokens
  # (e.g. ~/.claude/) survive pod restarts without re-authentication. On macOS
  # this is a VM-local ext4 dir — NOT the 9p-shared Mac home, where the gVisor
  # gofer would present the agent's own files as root-owned and break credential
  # persistence (login would report "Not logged in"). On Linux/WSL the host dir
  # is mounted directly. See prepare_agent_home / resolve_agent_home.
  prepare_agent_home "${opt_agent}"

  # Tier 2/3 on macOS: the agent works on a per-session VM-local ext4 copy of
  # each repo (the gVisor gofer cannot give the uid-1000 agent write access to a
  # repo mounted directly off the 9p Mac home). Create those copies and start
  # the in-VM Mutagen daemon that keeps them in near-live two-way sync with the
  # host repos, before the pod that hostPath-mounts them is applied. A no-op on
  # Linux/WSL and for tier 1. See prepare_workspace / resolve_workspace_mount.
  prepare_workspace "${session_id}" "${opt_repos[@]+"${opt_repos[@]}"}"

  local current_user="${USER:-$(id -un)}"
  local start_time
  start_time="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  # Collect all domains for this session
  local -a agent_domains=()
  read_into_array agent_domains < <(get_agent_domains "${opt_agent}")
  local -a tier_domains=()
  read_into_array tier_domains < <(get_tier_domains "${opt_tier}")
  local -a all_domains=("${agent_domains[@]+"${agent_domains[@]}"}" "${tier_domains[@]+"${tier_domains[@]}"}" "${opt_allow_domains[@]+"${opt_allow_domains[@]}"}")
  local domain_count="${#all_domains[@]}"

  # Pin the agent's conversation ID (when the agent supports it) so teardown
  # can copy the exact transcript file rather than guessing by mtime.
  local agent_session_id=""
  if [[ -n "$(get_agent_session_id_flag "${opt_agent}")" ]]; then
    agent_session_id="$(generate_uuid)"
  fi

  # Build JSON array form of the repo list for the audit record.
  local repos_json="[]"
  if [[ "${#opt_repos[@]}" -gt 0 ]]; then
    repos_json="$(printf '%s\n' "${opt_repos[@]}" | jq -R . | jq -s -c .)"
  fi

  # Snapshot the kube API server for 'sandbox allow' to use when it
  # rebuilds the policy later. Empty for Tier 1/2.
  if [[ -n "${kube_server_ip}" ]]; then
    SESSION_KUBE_API_CIDR="${kube_server_ip}/32"
  else
    SESSION_KUBE_API_CIDR=""
  fi
  SESSION_KUBE_API_PORT="${kube_server_port:-}"
  export SESSION_KUBE_API_CIDR SESSION_KUBE_API_PORT

  audit_write_session_json \
    "${log_dir}" \
    "${session_id}" \
    "${opt_agent}" \
    "${opt_tier}" \
    "${current_user}" \
    "${repos_json}" \
    "${opt_name}" \
    "${pod_name}" \
    "${start_time}" \
    "${all_domains[@]+"${all_domains[@]}"}"

  if [[ -n "${agent_session_id}" ]]; then
    audit_record_agent_session_id "${log_dir}" "${agent_session_id}"
  fi

  # Record the vetting-gate outcome now that session.json exists (the gate in
  # Step 2 runs before it, so it stashed the summary in SESSION_VETTING_SUMMARY).
  if [[ -n "${SESSION_VETTING_SUMMARY:-}" ]]; then
    audit_log_event "${log_dir}" "vetting" "${SESSION_VETTING_SUMMARY}"
  fi

  ###########################################################################
  # Step 5: Capture workspace baseline (Tier 2/3)
  ###########################################################################
  if [[ "${opt_tier}" -ge 2 ]] && [[ "${#opt_repos[@]}" -gt 0 ]]; then
    echo "==> Capturing workspace baseline..."
    capture_workspace_baseline "${log_dir}" "${opt_repos[@]}"
  fi

  ###########################################################################
  # Step 6: Select container image
  ###########################################################################
  local container_image
  if [[ "${opt_tier}" -eq 3 ]]; then
    container_image="docker.io/library/sandbox:${opt_agent}-infra"
  else
    container_image="docker.io/library/sandbox:${opt_agent}"
  fi
  echo "==> Image: ${container_image}"

  ###########################################################################
  # Step 7: Build CiliumNetworkPolicy
  ###########################################################################
  echo "==> Building network policy..."
  local kube_api_cidr=""
  [[ -n "${kube_server_ip}" ]] && kube_api_cidr="${kube_server_ip}/32"
  local policy_yaml
  policy_yaml="$(build_cilium_policy \
    "${session_id}" \
    "${opt_agent}" \
    "${opt_tier}" \
    "${kube_api_cidr}" \
    "${kube_server_port:-443}" \
    "${opt_infra_endpoints[@]+"${opt_infra_endpoints[@]}"}" \
    "${opt_allow_domains[@]+"${opt_allow_domains[@]}"}")"

  ###########################################################################
  # Step 8: Build pod manifest
  ###########################################################################
  echo "==> Building pod manifest..."
  local pod_yaml
  local infra_kubeconfig_flag=""
  [[ -n "${opt_infra_kubeconfig}" ]] && infra_kubeconfig_flag="1"
  pod_yaml="$(build_pod_manifest \
    "${session_id}" \
    "${opt_agent}" \
    "${opt_tier}" \
    "${container_image}" \
    "${opt_name}" \
    "${current_user}" \
    "${opt_infra_token}" \
    "${pod_name}" \
    "${infra_kubeconfig_flag}" \
    "${kube_server_ip}" \
    "${kube_server_host}" \
    "${opt_repos[@]+"${opt_repos[@]}"}")"

  ###########################################################################
  # Step 9: Apply policy and pod (or dry-run)
  ###########################################################################
  if [[ "${opt_dry_run}" == "true" ]]; then
    echo ""
    echo "==> DRY RUN — CiliumNetworkPolicy:"
    echo "${policy_yaml}"
    echo ""
    echo "==> DRY RUN — Pod manifest:"
    echo "${pod_yaml}"
    if [[ "${SESSION_HAS_DEPS:-false}" == "true" ]]; then
      echo ""
      echo "==> DRY RUN — Dependencies (after identity assertion at launch):"
      local _i _name _rname _port _catpath
      local -a _egress=()
      for _i in "${!SESSION_DEP_NAMES[@]}"; do
        _name="${SESSION_DEP_NAMES[$_i]}"
        _rname="${SESSION_DEP_RESOURCE_NAMES[$_i]}"
        _port="${SESSION_DEP_PORTS[$_i]}"
        _catpath="${SESSION_DEP_PATHS[$_i]}"
        _egress=()
        read_into_array _egress < <(catalogue_list "${_catpath}" egress)
        echo "--- dependency '${_name}' policy/pod/service ---"
        build_dependency_policy "${session_id}" "${_rname}" "${_port}" "${_egress[@]+"${_egress[@]}"}"
        build_dependency_pod_manifest "${session_id}" "${opt_tier}" "${_name}" "${_rname}" "${_catpath}" "" "" ""
        build_dependency_service "${session_id}" "${_name}" "${_rname}" "${_port}" "" ""
      done
      echo ""
      echo "==> DRY RUN — session policy WITH dependency reach (re-applied at launch):"
      SESSION_DEP_ENDPOINTS=("${SESSION_DEP_ENDPOINTS_PENDING[@]}")
      build_cilium_policy "${session_id}" "${opt_agent}" "${opt_tier}" \
        "${kube_api_cidr}" "${kube_server_port:-443}" \
        "${opt_infra_endpoints[@]+"${opt_infra_endpoints[@]}"}" \
        "${opt_allow_domains[@]+"${opt_allow_domains[@]}"}"
      SESSION_DEP_ENDPOINTS=()
      if [[ "${SESSION_HAS_MCPS:-false}" == "true" ]]; then
        echo ""
        echo "==> DRY RUN — MCP ConfigMap:"
        render_mcp_configmap "${session_id}" "${opt_agent}"
      fi
    fi
    echo ""
    echo "Dry run complete. No resources applied."
    return 0
  fi

  # Handle Tier 3 infra token secret (optional now that --infra-kubeconfig exists)
  local infra_secret_name=""
  if [[ "${opt_tier}" -eq 3 ]] && [[ -n "${opt_infra_token}" ]]; then
    infra_secret_name="infra-token-${session_id}"
    echo "==> Creating infra token secret: ${infra_secret_name}..."
    create_infra_token_secret "${infra_secret_name}" "${opt_infra_token}"
  fi

  # Profile-declared secrets: bundle the host-side values into one
  # session-scoped K8s Secret. Lifecycle matches infra-token — created
  # here, deleted at teardown in cmd_stop. PRINCIPLES.md rule 2:
  # secrets never persist in the cluster across sessions.
  if [[ "${SESSION_HAS_SECRETS}" == "true" ]]; then
    echo "==> Creating session secrets: $(session_secrets_name "${session_id}")..."
    create_session_secrets "${session_id}" "${SESSION_PROFILE_SECRETS_LIST[@]}"
  fi

  # Handle Tier 3 kubeconfig secret
  if [[ -n "${opt_infra_kubeconfig}" ]]; then
    local kc_secret_name="kubeconfig-${session_id}"
    echo "==> Creating kubeconfig secret: ${kc_secret_name}..."
    create_kubeconfig_secret "${kc_secret_name}" "${kubeconfig_minified}"
  fi

  # Create opencode API key secret before the pod references it
  if [[ "${opt_agent}" == "opencode" ]]; then
    echo "==> Creating opencode API key secret..."
    create_opencode_apikey_secret "${session_id}"
  fi

  # Phase 5: the per-session MCP ConfigMap is created BEFORE the pod, since the
  # pod mounts it (lib/manifest.sh). The dependency Service URLs are
  # deterministic from the session ID, so the config can be rendered before the
  # dependency pods exist. The dependencies themselves come up after the session
  # pod is Ready and its identity is asserted (Step 10b).
  if [[ "${SESSION_HAS_MCPS:-false}" == "true" ]]; then
    echo "==> Creating MCP config: ${SESSION_MCP_CONFIGMAP}..."
    create_mcp_configmap "${session_id}" "${opt_agent}"
  fi

  echo "==> Applying CiliumNetworkPolicy..."
  echo "${policy_yaml}" | kubectl apply -f - 2>&1

  echo "==> Applying pod..."
  echo "${pod_yaml}" | kubectl apply -f - 2>&1

  ###########################################################################
  # Step 10: Wait for pod Running
  ###########################################################################
  echo "==> Waiting for pod to become Ready..."
  wait_for_pod "${pod_name}"

  ###########################################################################
  # Step 10b: Bring up profile-declared dependencies (Phase 5)
  ###########################################################################
  # Order matters (§1.6): the session pod must be Ready and its per-session
  # Cilium identity asserted BEFORE any dependency toEndpoints rule is wired —
  # otherwise a collapsed identity would silently widen "only from the session
  # pod" to "from any session". Fail-closed throughout: any failure tears down
  # the partial session and aborts, because a profile asked for the dependency.
  if [[ "${SESSION_HAS_DEPS:-false}" == "true" ]]; then
    echo "==> Verifying per-session network identity..."
    if ! ( assert_session_identity_distinct "${pod_name}" ); then
      echo "==> Identity assertion failed; tearing down session ${session_id}." >&2
      cmd_stop "${session_id}" >/dev/null 2>&1 || true
      die "Per-session network identity could not be verified; aborted."
    fi

    # The session pod owns the dependency objects: Kubernetes GC reaps them if
    # this CLI dies after the pod exists. teardown_dependencies (label-keyed) is
    # the backstop for the window before the ownerRef is set.
    local owner_uid
    owner_uid="$(kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" \
      -o jsonpath='{.metadata.uid}' 2>/dev/null || true)"

    echo "==> Bringing up ${#SESSION_DEP_NAMES[@]} dependency/dependencies..."
    if ! bring_up_dependencies "${session_id}" "${opt_tier}" "${pod_name}" \
         "${owner_uid}" "${log_dir}"; then
      echo "==> Dependency startup failed; tearing down session ${session_id}." >&2
      cmd_stop "${session_id}" >/dev/null 2>&1 || true
      die "One or more dependencies failed to start; aborted."
    fi

    # Record the resolved dependencies (versions, egress allowlists, up-times)
    # in the audit trail now that they are Ready (§2.6).
    audit_record_dependencies "${log_dir}" \
      "$(session_dependencies_audit_json "$(date -u '+%Y-%m-%dT%H:%M:%SZ')")"

    # Identity is asserted and dependencies are Ready — now wire the session's
    # reach to them (toEndpoints + cluster-local DNS) by re-applying the policy.
    echo "==> Wiring session→dependency network reach..."
    SESSION_DEP_ENDPOINTS=("${SESSION_DEP_ENDPOINTS_PENDING[@]}")
    local dep_policy_yaml
    dep_policy_yaml="$(build_cilium_policy \
      "${session_id}" \
      "${opt_agent}" \
      "${opt_tier}" \
      "${kube_api_cidr}" \
      "${kube_server_port:-443}" \
      "${opt_infra_endpoints[@]+"${opt_infra_endpoints[@]}"}" \
      "${opt_allow_domains[@]+"${opt_allow_domains[@]}"}")"
    SESSION_DEP_ENDPOINTS=()
    echo "${dep_policy_yaml}" | kubectl apply -f - 2>&1
  fi

  ###########################################################################
  # Step 11: Show banner and attach
  ###########################################################################
  echo ""
  print_session_banner \
    "${session_id}" \
    "${opt_agent}" \
    "${opt_tier}" \
    "${domain_count}" \
    "${log_dir}" \
    "${opt_name}" \
    "${opt_repos[@]+"${opt_repos[@]}"}"
  echo ""

  # Build the agent launch command, pinning the conversation ID when supported
  # and disabling any broken inner OS-sandbox (Codex's bwrap; see
  # get_agent_sandbox_flags) at launch so it doesn't depend on onboard staging.
  local -a agent_cmd=("${opt_agent}")
  local sandbox_flags; local -a _sbf=()
  sandbox_flags="$(get_agent_sandbox_flags "${opt_agent}")"
  [[ -n "${sandbox_flags}" ]] && read -ra _sbf <<< "${sandbox_flags}" \
    && agent_cmd+=("${_sbf[@]}")
  if [[ -n "${agent_session_id}" ]]; then
    agent_cmd+=("$(get_agent_session_id_flag "${opt_agent}")" "${agent_session_id}")
  fi

  # Phase 5: point the agent at the session-scoped MCP config so it registers the
  # declared MCP dependencies (and, via --strict-mcp-config, nothing else).
  if [[ "${SESSION_HAS_MCPS:-false}" == "true" ]]; then
    local -a _mcp_args=()
    read_into_array _mcp_args < <(get_agent_mcp_launch_args "${opt_agent}")
    [[ "${#_mcp_args[@]}" -gt 0 ]] && agent_cmd+=("${_mcp_args[@]}")
  fi

  echo "==> Attaching to session (Ctrl-D or 'exit' to end)..."
  kubectl exec -n "${SANDBOX_NAMESPACE}" -it "${pod_name}" -c agent -- "${agent_cmd[@]}" || true

  ###########################################################################
  # Step 12: Disconnect — tear down by default; --keep-alive preserves the pod
  ###########################################################################
  echo ""
  if [[ "${opt_keep_alive}" == "true" ]]; then
    echo "==> Disconnected from session ${session_id} (pod kept alive)."
    echo "    Resume:  sandbox resume ${session_id}"
    echo "    Stop:    sandbox stop ${session_id}"
    echo "    Logs:    ${log_dir}"
  else
    echo "==> Disconnected — tearing down session to free cluster resources..."
    cmd_stop "${session_id}"
    echo ""
    echo "    Conversation history preserved in ~/.sandbox/agent-home/${opt_agent}/"
    echo "    To continue: start a new session and use the agent's /resume command."
  fi
}

###############################################################################
# cmd_list — list sessions
###############################################################################
cmd_list() {
  echo "Active pods in namespace '${SANDBOX_NAMESPACE}':"
  echo ""
  if ! kubectl get pods -n "${SANDBOX_NAMESPACE}" \
       -l "sandbox-session" \
       -o custom-columns='SESSION:.metadata.labels.sandbox-session,AGENT:.metadata.labels.sandbox-agent,TIER:.metadata.labels.sandbox-tier,NAME:.metadata.annotations.sandbox-name,STATUS:.status.phase,AGE:.metadata.creationTimestamp' \
       2>/dev/null; then
    echo "(could not reach cluster)"
  fi

  echo ""
  echo "Recent sessions (${SANDBOX_LOGS_DIR}):"
  echo ""
  if [[ -d "${SANDBOX_LOGS_DIR}" ]]; then
    local found=0
    for session_dir in "${SANDBOX_LOGS_DIR}"/ses-*/; do
      [[ -d "${session_dir}" ]] || continue
      local sid
      sid="$(basename "${session_dir}")"
      local session_json="${session_dir}/session.json"
      if [[ -f "${session_json}" ]]; then
        local agent tier name start end
        agent="$(jq -r '.agent // "?"' "${session_json}" 2>/dev/null || echo "?")"
        tier="$(jq -r '.tier // "?"' "${session_json}" 2>/dev/null || echo "?")"
        name="$(jq -r '.name // ""' "${session_json}" 2>/dev/null || echo "")"
        start="$(jq -r '.start_time // "?"' "${session_json}" 2>/dev/null || echo "?")"
        end="$(jq -r '.end_time // "running"' "${session_json}" 2>/dev/null || echo "running")"
        printf "  %-36s  %-10s  tier%-2s  %-24s  %s → %s\n" \
          "${sid}" "${agent}" "${tier}" "${name}" "${start}" "${end}"
      else
        printf "  %-36s  (no session.json)\n" "${sid}"
      fi
      found=1
    done
    if [[ "${found}" -eq 0 ]]; then
      echo "  (no sessions found)"
    fi
  else
    echo "  (log directory does not exist: ${SANDBOX_LOGS_DIR})"
  fi
}

###############################################################################
# cmd_logs — show session audit log
###############################################################################
cmd_logs() {
  local session_id="${1:?Usage: sandbox logs <SESSION_ID>}"
  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"

  if [[ ! -d "${log_dir}" ]]; then
    die "Session not found: ${session_id} (looked in ${log_dir})"
  fi

  echo "=== Session: ${session_id} ==="
  echo ""

  local session_json="${log_dir}/session.json"
  if [[ -f "${session_json}" ]]; then
    echo "--- session.json ---"
    jq . "${session_json}"
    echo ""
  fi

  local transcript_dir="${log_dir}/transcript"
  if [[ -d "${transcript_dir}" ]]; then
    echo "--- transcript (agent conversation) ---"
    local tf
    while IFS= read -r tf; do
      printf "  %s\n" "${tf}"
    done < <(find "${transcript_dir}" -type f | sort)
    echo ""
  fi

  local files_log="${log_dir}/files.log"
  if [[ -f "${files_log}" ]]; then
    echo "--- files.log (workspace changes) ---"
    cat "${files_log}"
    echo ""
  fi
}

###############################################################################
# cmd_flows — show Hubble network flows
###############################################################################
cmd_flows() {
  local session_id="${1:?Usage: sandbox flows <SESSION_ID>}"
  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"

  if [[ ! -d "${log_dir}" ]]; then
    die "Session not found: ${session_id} (looked in ${log_dir})"
  fi

  local flows_json="${log_dir}/flows.json"
  if [[ -f "${flows_json}" ]]; then
    echo "=== Hubble flows for ${session_id} ==="
    jq . "${flows_json}"
  else
    # Try live query if pod is still running
    local pod_name
    pod_name="$(resolve_pod_name "${session_id}")"
    if kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" &>/dev/null; then
      echo "==> Session is still running; querying Hubble live..."
      kubectl -n kube-system exec ds/cilium -- \
        hubble observe --namespace "${SANDBOX_NAMESPACE}" \
        --label "sandbox-session=${session_id}" \
        --output json 2>/dev/null || warn "Could not query Hubble via the Cilium agent."
    else
      echo "(no flows.json found and session is not running)"
    fi
  fi
}

###############################################################################
# cmd_stop — stop a session and run full teardown
###############################################################################
cmd_stop() {
  local session_id="${1:?Usage: sandbox stop <SESSION_ID>}"
  local pod_name
  pod_name="$(resolve_pod_name "${session_id}")"
  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"
  local session_json="${log_dir}/session.json"

  echo "==> Stopping session: ${session_id}"

  # Read session metadata so teardown can run audit steps
  local tier="1"
  local -a repos=()
  local agent=""
  local agent_session_id=""
  if [[ -f "${session_json}" ]]; then
    tier="$(jq -r '.tier // "1"' "${session_json}" 2>/dev/null || echo "1")"
    # Read `.repos` (array, new schema); fall back to `[.repo]` for old
    # session.json files written before the multi-repo refactor.
    read_into_array repos < <(jq -r '
      (.repos // [.repo])
      | map(select(. != null and . != ""))
      | .[]
    ' "${session_json}" 2>/dev/null || true)
    agent="$(jq -r '.agent // ""' "${session_json}" 2>/dev/null || echo "")"
    agent_session_id="$(jq -r '.agent_session_id // ""' "${session_json}" 2>/dev/null || echo "")"
  fi

  # Workspace diff (Tier 2/3)
  if [[ "${tier}" -ge 2 ]] && [[ "${#repos[@]}" -gt 0 ]]; then
    # macOS: flush the agent's final edits from the VM-local copy back to the
    # host repos and tear down the Mutagen sessions FIRST, so the diff below
    # (which reads the host paths) reflects the completed work. No-op elsewhere.
    teardown_workspace_sync "${session_id}"
    echo "==> Capturing workspace diff..."
    capture_workspace_diff "${log_dir}" "${repos[@]}"
  fi

  # Capture the agent conversation transcript into the session log directory.
  # On macOS the agent-home the pod wrote to is VM-local; sync it back to the
  # host staging dir first so the capture (which reads the host path) and the
  # durable token backup are current. No-op on Linux/WSL.
  if [[ -n "${agent}" ]]; then
    sync_agent_home_back "${agent}"
    echo "==> Capturing conversation transcript..."
    audit_capture_transcript "${log_dir}" "${agent}" \
      "$(host_agent_home "${agent}")" "${agent_session_id}"
  fi

  # Export Hubble flows
  echo "==> Exporting Hubble flows..."
  export_hubble_flows "${session_id}" "${log_dir}" \
    || warn "Could not export Hubble flows (is hubble CLI available?)"

  # Delete pod
  if kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" &>/dev/null 2>&1; then
    kubectl delete pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" --grace-period=10 2>&1
    echo "  Pod deleted."
  else
    warn "Pod ${pod_name} not found (already stopped)."
  fi

  # Delete network policy
  kubectl delete ciliumnetworkpolicy -n "${SANDBOX_NAMESPACE}" \
    "policy-${session_id}" --ignore-not-found=true 2>&1 || true

  # Phase 5: reap per-session dependency objects (pods, Services, CNPs) and the
  # MCP ConfigMap. Deleting the session pod above already triggers Kubernetes GC
  # via ownerReferences; this label-keyed sweep is the backstop covering the
  # window before an ownerRef was set and the case where the pod never existed.
  # No-op when the session declared no dependencies.
  teardown_dependencies "${session_id}"

  # Delete infra token secret if present (Tier 3)
  local infra_secret_name="infra-token-${session_id}"
  if kubectl get secret -n "${SANDBOX_NAMESPACE}" "${infra_secret_name}" \
       &>/dev/null 2>&1; then
    kubectl delete secret -n "${SANDBOX_NAMESPACE}" "${infra_secret_name}" \
      --ignore-not-found=true 2>&1 || true
    warn "REMINDER: Revoke infra token used in this session."
  fi

  # Delete kubeconfig secret if present (Tier 3 --infra-kubeconfig)
  local kc_secret_name="kubeconfig-${session_id}"
  if kubectl get secret -n "${SANDBOX_NAMESPACE}" "${kc_secret_name}" \
       &>/dev/null 2>&1; then
    delete_kubeconfig_secret "${session_id}"
    warn "REMINDER: kubeconfig credentials used in this session may still be"
    warn "         valid on the target cluster. Rotate or let them expire."
  fi

  # Delete opencode API key secret if present
  delete_opencode_apikey_secret "${session_id}"

  # Delete profile-declared session-secrets bundle if present. No-op
  # when the session didn't use any. PRINCIPLES.md rule 2.
  delete_session_secrets "${session_id}"

  # Mark session ended
  if [[ -d "${log_dir}" ]]; then
    local end_time
    end_time="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    audit_update_end_time "${log_dir}" "${end_time}"
    # Stamp the dependency down-times alongside the session end (§2.6). No-op
    # when the session declared no dependencies.
    audit_record_dependencies_down "${log_dir}" "${end_time}"
  fi

  echo ""
  echo "Session ${session_id} stopped."
  echo "Logs: ${log_dir}"
}

###############################################################################
# cmd_resume — reconnect to a running session
###############################################################################
cmd_resume() {
  local opt_keep_alive="false"
  local session_id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-alive) opt_keep_alive="true" ;;
      --help|-h)    echo "Usage: sandbox resume <SESSION_ID> [--keep-alive]"; exit 0 ;;
      -*)           die "Unknown option: $1" ;;
      *)
        if [[ -z "${session_id}" ]]; then
          session_id="$1"
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
    shift
  done

  [[ -n "${session_id}" ]] || die "Usage: sandbox resume <SESSION_ID> [--keep-alive]"

  local pod_name
  pod_name="$(resolve_pod_name "${session_id}")"
  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"
  local session_json="${log_dir}/session.json"

  if [[ ! -f "${session_json}" ]]; then
    die "Session not found: ${session_id} (no session.json in ${log_dir})"
  fi

  local agent
  agent="$(jq -r '.agent // "claude"' "${session_json}" 2>/dev/null || echo "claude")"
  local agent_session_id
  agent_session_id="$(jq -r '.agent_session_id // ""' "${session_json}" 2>/dev/null || echo "")"

  if ! kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" &>/dev/null 2>&1; then
    die "Pod ${pod_name} not found. Use 'sandbox list' to check session state."
  fi

  local pod_phase
  pod_phase="$(kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" \
    -o jsonpath='{.status.phase}' 2>/dev/null || echo "Unknown")"
  if [[ "${pod_phase}" != "Running" ]]; then
    die "Pod is not running (phase: ${pod_phase}). Use 'sandbox stop ${session_id}' to clean up."
  fi

  echo "==> Resuming session: ${session_id}"
  echo "    Agent: ${agent}  |  Log: ${log_dir/#${HOME}/\~}"
  echo ""

  # Re-attach to the same conversation when the agent supports resume-by-ID,
  # so the reconnect continues this session's existing transcript file. Pin the
  # inner OS-sandbox the same way 'run' does (see get_agent_sandbox_flags).
  local -a agent_cmd=("${agent}")
  local sandbox_flags; local -a _sbf=()
  sandbox_flags="$(get_agent_sandbox_flags "${agent}")"
  [[ -n "${sandbox_flags}" ]] && read -ra _sbf <<< "${sandbox_flags}" \
    && agent_cmd+=("${_sbf[@]}")
  local resume_flag
  resume_flag="$(get_agent_resume_flag "${agent}")"
  if [[ -n "${agent_session_id}" ]] && [[ -n "${resume_flag}" ]]; then
    agent_cmd+=("${resume_flag}" "${agent_session_id}")
  fi

  kubectl exec -n "${SANDBOX_NAMESPACE}" -it "${pod_name}" -c agent -- "${agent_cmd[@]}" || true

  echo ""
  if [[ "${opt_keep_alive}" == "true" ]]; then
    echo "==> Disconnected from session ${session_id} (pod kept alive)."
    echo "    Resume:  sandbox resume ${session_id}"
    echo "    Stop:    sandbox stop ${session_id}"
  else
    echo "==> Disconnected — tearing down session to free cluster resources..."
    cmd_stop "${session_id}"
    echo ""
    echo "    Conversation history preserved in ~/.sandbox/agent-home/${agent}/"
    echo "    To continue: start a new session and use the agent's /resume command."
  fi
}

###############################################################################
# cmd_cleanup — remove old session logs
###############################################################################
cmd_cleanup() {
  local older_than_days="90"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --older-than) older_than_days="${2:?--older-than requires a value}"; shift ;;
      --older-than=*) older_than_days="${1#--older-than=}" ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done

  echo "==> Cleaning sessions older than ${older_than_days} days..."

  if [[ ! -d "${SANDBOX_LOGS_DIR}" ]]; then
    echo "No log directory found."
    return 0
  fi

  local count=0
  while IFS= read -r -d '' session_dir; do
    local sid
    sid="$(basename "${session_dir}")"
    echo "  Removing: ${sid}"
    rm -rf "${session_dir}"
    (( count++ )) || true
  done < <(find "${SANDBOX_LOGS_DIR}" -maxdepth 1 -name 'ses-*' -type d \
             -mtime "+${older_than_days}" -print0 2>/dev/null)

  echo "Removed ${count} session(s)."
}

###############################################################################
# cmd_check — pre-flight workspace check
###############################################################################
cmd_check() {
  local workspace="${1:?Usage: sandbox check <WORKSPACE_PATH>}"
  workspace="${workspace/#\~/${HOME}}"

  echo "==> Checking workspace: ${workspace}"

  validate_repo_path "${workspace}"
  workspace_prescan "${workspace}"

  # Preview the secret gate: report unmasked findings but never fail —
  # 'check' is informational. 'sandbox run' applies the real gate.
  if command -v betterleaks &>/dev/null; then
    echo "  Scanning for unmasked secrets with betterleaks (preview)..."
    local _m _rel _rule _ln _match _unmasked=0 _encrypted=0 _accepted=0 _gitconfig=0 _scan_failed=false
    local -a _entries=()
    # Honor the vetted exceptions list in the preview exactly as the gate will.
    local _accept_file; _accept_file="$(mktemp "${TMPDIR:-/tmp}/sandbox-accept-XXXXXX")"
    vetted_accepted_fingerprints "${workspace}" > "${_accept_file}" 2>/dev/null || true
    while IFS=$'\t' read -r _m _rel _rule _ln _match; do
      [[ -z "${_rel}" ]] && continue
      if [[ "${_m}" == "error" ]]; then
        _scan_failed=true
      elif [[ "${_m}" == "sealed" ]]; then
        (( _encrypted++ )) || true
      elif [[ "${_m}" == "accepted" ]]; then
        (( _accepted++ )) || true
      elif [[ "${_m}" == "no" || "${_m}" == "gitconfig" ]]; then
        (( _unmasked++ )) || true
        echo "  UNMASKED: ${_rel}:${_rule}:${_ln}"
        if [[ "${_m}" == "no" ]]; then
          _entries+=("${workspace}"$'\t'"${_rel}"$'\t'"${_rule}"$'\t'"${_ln}"$'\t'"${_match}")
        else
          (( _gitconfig++ )) || true
        fi
      fi
    done < <(scan_repo_secrets "${workspace}" "${_accept_file}")
    rm -f "${_accept_file}"
    if [[ "${_encrypted}" -gt 0 ]]; then
      echo "  ${_encrypted} encrypted-at-rest finding(s) (SealedSecret/SOPS) — safe, not gated."
    fi
    if [[ "${_accepted}" -gt 0 ]]; then
      echo "  ${_accepted} finding(s) accepted via the vetted exceptions list — not gated."
    fi
    if [[ "${_scan_failed}" == true ]]; then
      echo "  WARN: betterleaks scan failed; 'sandbox run' would refuse to launch (fail closed)."
    elif [[ "${_unmasked}" -gt 0 ]]; then
      echo "  ${_unmasked} unmasked secret(s) would block 'sandbox run'."
      if [[ "${#_entries[@]}" -gt 0 ]]; then
        echo "  Mask them:"
        _print_mask_add_commands "${_entries[@]}" 2>&1
        echo "  Or record reviewed false positives as exceptions (honored once the"
        echo "  repo is vetted — 'sandbox vet'):"
        _print_exceptions_add_commands "${_entries[@]}" 2>&1
      fi
      if [[ "${_gitconfig}" -gt 0 ]]; then
        echo "  .git/config finding(s) cannot be masked; scrub the credential instead:"
        echo "        git -C ${workspace} remote set-url origin <https-url-without-credentials>"
      fi
    else
      echo "  betterleaks: no unmasked secrets."
    fi
  else
    echo "  WARN: betterleaks not found; 'sandbox run' would refuse to launch (fail closed)."
  fi

  echo ""
  echo "Workspace check passed."
}

###############################################################################
# cmd_status — cluster and sandbox status
###############################################################################
# --- infra version inspection (shared by `status` and `upgrade`) -------------

# infra_provisioned_version KEY — read a value (e.g. K3S_VERSION) from the
# manifest setup/upgrade wrote. Empty if unrecorded.
infra_provisioned_version() {
  local key="$1"
  [[ -f "${SANDBOX_INFRA_VERSIONS_FILE}" ]] || return 0
  local line
  line="$(grep -m1 "^${key}=" "${SANDBOX_INFRA_VERSIONS_FILE}" 2>/dev/null || true)"
  echo "${line#*=}"
}

# infra_installed_k3s — the k3s/Kubernetes version actually running, from the
# node's kubeletVersion (e.g. v1.31.4+k3s1). Cross-platform via the sandbox
# kubeconfig; empty if the cluster is unreachable.
infra_installed_k3s() {
  kubectl get nodes -o jsonpath='{.items[0].status.nodeInfo.kubeletVersion}' 2>/dev/null || true
}

# infra_installed_cilium — the running Cilium version, parsed from the agent
# DaemonSet image tag (…/cilium:vX.Y.Z@sha256:…) → bare vX.Y.Z.
infra_installed_cilium() {
  local image
  image="$(kubectl -n kube-system get ds cilium \
    -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null || true)"
  [[ -n "${image}" ]] || return 0
  # Image is repo[:tag][@sha256:digest]. Strip the @digest FIRST (its own colon
  # would otherwise defeat ##*:), then take the tag after the final colon.
  local no_digest="${image%%@*}"
  echo "${no_digest##*:}"
}

# infra_installed_gvisor — the runsc release from `runsc --version` (first line:
# "runsc version release-YYYYMMDD.N"). Host-local: meaningful on Linux; on macOS
# runsc lives in the VM, so this prints empty.
infra_installed_gvisor() {
  command -v runsc &>/dev/null || return 0
  runsc --version 2>/dev/null | head -1 | sed -E 's/.*release-?//; s/[[:space:]].*//' || true
}

# infra_version_line LABEL PINNED INSTALLED — one aligned status row with a drift
# flag. Comparison strips a leading 'v' so chart "1.16.5" matches image "v1.16.5".
# Empty installed (unreachable / in-VM) is reported as unknown, not drift.
infra_version_line() {
  local label="$1" pinned="$2" installed="$3"
  local note
  if [[ -z "${installed}" ]]; then
    note="${C_YELLOW}(installed unknown)${C_RESET}"
  elif [[ -z "${pinned}" || "${pinned}" == "latest" || "${pinned#v}" == "${installed#v}" ]]; then
    note="$(c_ok ok)"
  else
    note="${C_YELLOW}drift: pinned ${pinned}, installed ${installed}${C_RESET}"
  fi
  printf '  %-8s pinned %-14s installed %-14s %s\n' \
    "${label}:" "${pinned:--}" "${installed:--}" "${note}"
}

cmd_status() {
  echo "=== Sandbox Status ==="
  echo ""

  # Platform
  local platform
  platform="$(detect_platform)"
  echo "Platform:    ${platform}"
  echo "Version:     ${SANDBOX_VERSION}"
  echo ""

  # Lima (macOS only)
  if [[ "${platform}" == "macos" ]]; then
    echo "Lima VM:"
    if lima_vm_running; then
      echo "  Status: $(c_ok running)"
    else
      echo "  Status: $(c_err stopped) (run 'sandbox setup' or 'limactl start sandbox-vm')"
    fi
    echo ""
  fi

  # Cluster
  echo "Kubernetes cluster:"
  if kubectl cluster-info &>/dev/null 2>&1; then
    kubectl cluster-info 2>&1 | head -5
    echo ""
    echo "Nodes:"
    kubectl get nodes -o wide 2>&1 || true
  else
    echo "  ${C_RED}(cluster not reachable)${C_RESET}"
  fi
  echo ""

  # Cilium
  echo "Cilium:"
  if kubectl get pods -n kube-system -l k8s-app=cilium \
       -o jsonpath='{.items[*].status.phase}' 2>/dev/null | grep -q Running; then
    echo "  Status: $(c_ok running)"
    # Check policy enforcement mode
    if kubectl get configmap -n kube-system cilium-config \
         -o jsonpath='{.data.enable-policy}' 2>/dev/null | grep -q always; then
      echo "  PolicyEnforcementMode: $(c_ok always) (correct)"
    else
      echo "  PolicyEnforcementMode: ${C_YELLOW}may not be 'always'${C_RESET}"
    fi
  else
    echo "  Status: ${C_RED}not running${C_RESET}"
  fi
  echo ""

  # gVisor
  echo "gVisor RuntimeClass:"
  if kubectl get runtimeclass gvisor &>/dev/null 2>&1; then
    echo "  Status: $(c_ok configured)"
  else
    echo "  Status: ${C_RED}not found${C_RESET} (run 'sandbox setup')"
  fi
  echo ""

  # Infra component versions (pinned in setup/versions.sh vs what's live).
  # Drift here means someone ran an older setup, or an upgrade is available —
  # this is the CVE/EOL view. 'sandbox upgrade' moves the live cluster to pins.
  echo "Infra versions:"
  infra_version_line "k3s"    "${SANDBOX_K3S_VERSION}"    "$(infra_installed_k3s)"
  infra_version_line "Cilium" "${SANDBOX_CILIUM_VERSION}" "$(infra_installed_cilium)"
  infra_version_line "gVisor" "${SANDBOX_GVISOR_RELEASE}" "$(infra_installed_gvisor)"
  local provisioned_at
  provisioned_at="$(infra_provisioned_version RECORDED_AT)"
  if [[ -n "${provisioned_at}" ]]; then
    echo "  (provisioned ${provisioned_at}; pins from setup/versions.sh)"
  else
    echo "  (no provisioning record yet — run 'sandbox install')"
  fi
  echo ""

  # Sandbox namespace
  echo "Sandbox namespace:"
  if kubectl get namespace "${SANDBOX_NAMESPACE}" &>/dev/null 2>&1; then
    echo "  Status: $(c_ok exists)"
    local pod_count
    pod_count="$(kubectl get pods -n "${SANDBOX_NAMESPACE}" --no-headers 2>/dev/null | wc -l | tr -d ' ')"
    echo "  Running sessions: ${pod_count}"
  else
    echo "  Status: not found (run 'sandbox setup')"
  fi
}

###############################################################################
# cmd_rebuild — rebuild sandbox container image(s)
#
# container images").
#
# Rebuilds one or more sandbox:* images without re-running the full setup.
# Useful when an agent CLI has a new release (e.g. Claude Code updates for
# new Anthropic model support) and the existing cached image needs to be
# refreshed.
###############################################################################

usage_rebuild() {
  cat <<EOF
sandbox rebuild — Rebuild sandbox container image(s)

USAGE:
  sandbox rebuild [OPTIONS]

OPTIONS:
  --agent <NAME>               Image to rebuild. One of:
                                 claude, codex, opencode, copilot, grok, shell, base, all
                                 (default: all)
  --tier3                      Also rebuild the matching *-infra image(s)
  --no-cache                   Pass --no-cache to the container builder
  --codex-version <VER>        Pin @openai/codex npm version (default: latest)
  --opencode-version <VER>     Pin OpenCode release (default: latest)
  --copilot-version <VER>      Pin @github/copilot npm version (default: latest)
  --grok-version <VER>         Pin Grok CLI release, e.g. 0.2.93 (semver only)
  --help                       Show this help

NOTES:
  - 'sandbox:base' is only rebuilt when --agent base or --agent all is given.
    Agent images depend on base; if base is missing, rebuild with --agent all.
  - By default, rebuilding the claude image cache-busts the Claude Code
    install layer using a timestamp build arg, so the latest release is
    always fetched from https://claude.ai/install.sh.
  - On Linux, rebuilt images are re-imported into k3s containerd automatically.
  - Version info for rebuilt images is recorded at:
      ${SANDBOX_LOGS_DIR}/image-builds.log

EXAMPLES:
  sandbox rebuild --agent claude
  sandbox rebuild --agent claude --tier3
  sandbox rebuild --agent all --no-cache
  sandbox rebuild --agent codex --codex-version 0.2.1
EOF
  exit 0
}

cmd_rebuild() {
  local opt_agent="all"
  local opt_tier3="false"
  local opt_no_cache="false"
  local opt_codex_version=""
  local opt_opencode_version=""
  local opt_copilot_version=""
  local opt_grok_version=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent)             opt_agent="${2:?--agent requires a value}"; shift ;;
      --agent=*)           opt_agent="${1#--agent=}" ;;
      --tier3)             opt_tier3="true" ;;
      --no-cache)          opt_no_cache="true" ;;
      --codex-version)     opt_codex_version="${2:?--codex-version requires a value}"; shift ;;
      --codex-version=*)   opt_codex_version="${1#--codex-version=}" ;;
      --opencode-version)  opt_opencode_version="${2:?--opencode-version requires a value}"; shift ;;
      --opencode-version=*) opt_opencode_version="${1#--opencode-version=}" ;;
      --copilot-version)   opt_copilot_version="${2:?--copilot-version requires a value}"; shift ;;
      --copilot-version=*) opt_copilot_version="${1#--copilot-version=}" ;;
      --grok-version)      opt_grok_version="${2:?--grok-version requires a value}"; shift ;;
      --grok-version=*)    opt_grok_version="${1#--grok-version=}" ;;
      --help|-h)           usage_rebuild ;;
      *)                   die "Unknown option: $1 (run 'sandbox rebuild --help')" ;;
    esac
    shift
  done

  case "${opt_agent}" in
    claude|codex|opencode|copilot|grok|shell|base|all) ;;
    *) die "Invalid --agent: ${opt_agent} (must be claude, codex, opencode, copilot, grok, shell, base, or all)" ;;
  esac

  # Container builder — match setup/common.sh preference order.
  local container_cli=""
  if command -v docker &>/dev/null; then
    container_cli="docker"
  elif command -v podman &>/dev/null; then
    container_cli="podman"
  else
    die "Neither docker nor podman found. Install one and retry."
  fi

  local platform
  platform="$(detect_platform)"
  if [[ "${platform}" == "macos" ]]; then
    echo "==> Rebuild on macOS must be run inside the Lima VM."
    echo "    limactl shell sandbox-vm -- sandbox rebuild $*"
    exit 1
  fi

  local docker_dir="${SANDBOX_ROOT}/docker"
  mkdir -p "${SANDBOX_LOGS_DIR}"
  local build_log="${SANDBOX_LOGS_DIR}/image-builds.log"

  echo "==> Rebuilding sandbox image(s): ${opt_agent}"
  echo "    Builder:  ${container_cli}"
  echo "    No-cache: ${opt_no_cache}"
  echo "    Tier 3:   ${opt_tier3}"
  echo ""

  # Build flags applied to every build invocation.
  local -a common_flags=()
  [[ "${opt_no_cache}" == "true" ]] && common_flags+=("--no-cache")

  # _rebuild_one <tag> <dockerfile> [extra build args...]
  _rebuild_one() {
    local tag="$1"; local dockerfile="$2"; shift 2
    if [[ ! -f "${docker_dir}/${dockerfile}" ]]; then
      die "Dockerfile not found: ${docker_dir}/${dockerfile}"
    fi
    echo "==> Building ${tag} (${dockerfile})"
    "${container_cli}" build "${common_flags[@]}" \
      -t "${tag}" -f "${docker_dir}/${dockerfile}" "$@" "${docker_dir}"
    _import_to_k3s "${tag}"
    _record_build "${tag}"
  }

  _import_to_k3s() {
    local tag="$1"
    if [[ "${platform}" != "linux" ]]; then return 0; fi
    if ! command -v k3s &>/dev/null; then
      warn "k3s not found — skipping containerd import for ${tag}"
      return 0
    fi
    echo "    Importing ${tag} into k3s containerd..."
    "${container_cli}" save "${tag}" | sudo k3s ctr images import -
  }

  # _record_build <tag> — append version info to image-builds.log
  _record_build() {
    local tag="$1"
    local version_cmd=""
    case "${tag}" in
      sandbox:claude|sandbox:claude-infra)     version_cmd="claude --version" ;;
      sandbox:codex|sandbox:codex-infra)       version_cmd="codex --version" ;;
      sandbox:opencode|sandbox:opencode-infra) version_cmd="opencode --version" ;;
      sandbox:copilot|sandbox:copilot-infra)   version_cmd="copilot --version" ;;
      sandbox:grok|sandbox:grok-infra)         version_cmd="grok --version" ;;
      sandbox:shell)                           version_cmd="bash --version | head -1" ;;
      sandbox:base)                            version_cmd="node --version" ;;
    esac

    local agent_ver="(unknown)"
    if [[ -n "${version_cmd}" ]]; then
      agent_ver="$("${container_cli}" run --rm --entrypoint sh "${tag}" \
                   -c "${version_cmd}" 2>/dev/null | head -1 || echo '(unknown)')"
    fi
    local ts
    ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    echo "${ts}  ${tag}  ${agent_ver}" >> "${build_log}"
    echo "    Recorded: ${tag} → ${agent_ver}"
  }

  # Resolve the agent-build args — cache-bust for claude, version pin for codex/opencode.
  local -a claude_args=()
  local claude_rev
  claude_rev="$(date -u '+%Y%m%d%H%M%S')"
  claude_args+=(--build-arg "CLAUDE_CODE_INSTALL_REV=${claude_rev}")

  local -a codex_args=()
  [[ -n "${opt_codex_version}" ]] && codex_args+=(--build-arg "CODEX_VERSION=${opt_codex_version}")

  local -a opencode_args=()
  [[ -n "${opt_opencode_version}" ]] && opencode_args+=(--build-arg "OPENCODE_VERSION=${opt_opencode_version}")

  local -a copilot_args=()
  [[ -n "${opt_copilot_version}" ]] && copilot_args+=(--build-arg "COPILOT_CLI_VERSION=${opt_copilot_version}")

  local -a grok_args=()
  [[ -n "${opt_grok_version}" ]] && grok_args+=(--build-arg "GROK_CLI_VERSION=${opt_grok_version}")

  # Build in dependency order.
  if [[ "${opt_agent}" == "base" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:base" "Dockerfile.base"
  fi

  if [[ "${opt_agent}" == "claude" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:claude" "Dockerfile.claude" "${claude_args[@]}"
  fi
  if [[ "${opt_agent}" == "codex" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:codex" "Dockerfile.codex" "${codex_args[@]}"
  fi
  if [[ "${opt_agent}" == "opencode" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:opencode" "Dockerfile.opencode" "${opencode_args[@]}"
  fi
  if [[ "${opt_agent}" == "copilot" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:copilot" "Dockerfile.copilot" "${copilot_args[@]+"${copilot_args[@]}"}"
  fi
  if [[ "${opt_agent}" == "grok" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:grok" "Dockerfile.grok" "${grok_args[@]+"${grok_args[@]}"}"
  fi
  if [[ "${opt_agent}" == "shell" || "${opt_agent}" == "all" ]]; then
    _rebuild_one "docker.io/library/sandbox:shell" "Dockerfile.shell"
  fi

  # Tier 3 infra variants — only rebuild for agents that have them.
  if [[ "${opt_tier3}" == "true" || "${opt_agent}" == "all" ]]; then
    if [[ "${opt_agent}" == "claude" || "${opt_agent}" == "all" ]]; then
      _rebuild_one "docker.io/library/sandbox:claude-infra" "Dockerfile.infra" \
        --build-arg "BASE_IMAGE=sandbox:claude"
    fi
    if [[ "${opt_agent}" == "codex" || "${opt_agent}" == "all" ]]; then
      _rebuild_one "docker.io/library/sandbox:codex-infra" "Dockerfile.infra" \
        --build-arg "BASE_IMAGE=sandbox:codex"
    fi
    if [[ "${opt_agent}" == "opencode" || "${opt_agent}" == "all" ]]; then
      _rebuild_one "docker.io/library/sandbox:opencode-infra" "Dockerfile.infra" \
        --build-arg "BASE_IMAGE=sandbox:opencode"
    fi
    if [[ "${opt_agent}" == "copilot" || "${opt_agent}" == "all" ]]; then
      _rebuild_one "docker.io/library/sandbox:copilot-infra" "Dockerfile.infra" \
        --build-arg "BASE_IMAGE=sandbox:copilot"
    fi
    if [[ "${opt_agent}" == "grok" || "${opt_agent}" == "all" ]]; then
      _rebuild_one "docker.io/library/sandbox:grok-infra" "Dockerfile.infra" \
        --build-arg "BASE_IMAGE=sandbox:grok"
    fi
  fi

  echo ""
  echo "==> Rebuild complete. Build log: ${build_log}"
}

###############################################################################
# cmd_setup — install/configure prerequisites (exposed as both `install` and
# `setup`). Thin wrapper over setup.sh; all flags (--pod-cidr, --service-cidr,
# --apiserver-port, --dns) pass straight through.
###############################################################################
cmd_setup() {
  echo "==> Running sandbox install..."
  bash "${SANDBOX_ROOT}/setup.sh" "$@"
}

###############################################################################
# cmd_uninstall — tear down the cluster and host artifacts. Thin wrapper over
# uninstall.sh; flags (--yes, --keep-logs, --keep-images, --keep-lima,
# --keep-kubetools) pass straight through.
###############################################################################
cmd_uninstall() {
  bash "${SANDBOX_ROOT}/uninstall.sh" "$@"
}

###############################################################################
# cmd_upgrade — move the install forward: the app (this CLI, default) and/or the
# host infra components (k3s/Cilium/gVisor). Delegates to _upgrade_app_phase and
# _upgrade_infra_phase; see usage_upgrade for the flag model.
###############################################################################
usage_upgrade() {
  cat <<EOF
sandbox upgrade — move your install forward (the CLI app and/or host infra)

USAGE:
  sandbox upgrade [TARGET] [OPTIONS]

TARGET (default: --app):
  --app                Update the CLI itself to the latest release (default)
  --infra              Upgrade all host infra: k3s, Cilium, gVisor, betterleaks
  --k3s                Upgrade k3s only
  --cilium             Upgrade Cilium only
  --gvisor             Upgrade gVisor (runsc) only
  --betterleaks        Upgrade the betterleaks secret scanner only
  --all                Both: update the app, then the infra (in that order)

APP OPTIONS (--app):
  --to <vX.Y.Z>        Update to a specific release tag (default: latest)
  --remote <name>      Git remote to fetch releases from (default: origin)
  --rebuild            After updating, rebuild agent images ('sandbox rebuild')

INFRA OPTIONS (--infra / components):
  --to-k3s <ver>       Override the k3s target (else setup/versions.sh pin)
  --to-cilium <ver>    Override the Cilium chart target
  --to-gvisor <rel>    Override the gVisor release id (YYYYMMDD.N)
  --to-betterleaks <ver>  Override the betterleaks target (bare X.Y.Z)
  --force              Proceed even if sessions are running (they may be killed)

SHARED OPTIONS:
  --dry-run            Show the plan and exit; make no changes
  -y, --yes            Skip the confirmation prompt
  -h, --help           Show this help

The app phase fast-forwards this checkout to the latest RELEASE tag (never the
tip of a branch), and only when it is a clean fast-forward — local edits and
local commits are never discarded. A released tarball (no .git) cannot
self-update; the command prints the download link instead.

The infra phase re-runs the component installers, which restarts k3s and can
briefly disrupt the Cilium datapath — hence the running-session guard. Infra
targets default to the pins in setup/versions.sh (which Renovate keeps current).
On macOS the k3s/Cilium/gVisor stack lives inside the Lima VM and is not upgraded
in place yet; re-provision the VM instead (the command prints how). betterleaks
is the exception: it is a host-side binary, so it upgrades on any platform and
without the session guard (swapping it neither restarts k3s nor drops sessions).

With --all the app is updated first, then the CLI re-executes itself so the
infra phase applies the newly pulled pins.
EOF
  exit 0
}

cmd_upgrade() {
  # Target selection. Default (no target flag) is the APP: fast-forward this CLI
  # checkout to the latest release — the safe, no-cluster-impact operation. Infra
  # work (which restarts k3s and can drop live sessions) is opt-in via --infra,
  # the individual component flags, or --all.
  local want_app=false want_infra=false explicit_target=false
  local do_k3s=false do_cilium=false do_gvisor=false do_betterleaks=false
  local to_k3s="" to_cilium="" to_gvisor="" to_betterleaks=""
  local to="" remote="origin" do_rebuild=false
  local force=false assume_yes=false dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      # Target buckets
      --app)          want_app=true;   explicit_target=true; shift ;;
      --infra)        want_infra=true; explicit_target=true; shift ;;
      --all)          want_app=true; want_infra=true; explicit_target=true; shift ;;
      # Individual infra components (each implies the infra phase)
      --k3s)          do_k3s=true;    explicit_target=true; shift ;;
      --cilium)       do_cilium=true; explicit_target=true; shift ;;
      --gvisor)       do_gvisor=true; explicit_target=true; shift ;;
      --betterleaks)  do_betterleaks=true; explicit_target=true; shift ;;
      # Infra target overrides (else setup/versions.sh pins)
      --to-k3s)       to_k3s="$2";         do_k3s=true;    explicit_target=true; shift 2 ;;
      --to-k3s=*)     to_k3s="${1#*=}";    do_k3s=true;    explicit_target=true; shift ;;
      --to-cilium)    to_cilium="$2";      do_cilium=true; explicit_target=true; shift 2 ;;
      --to-cilium=*)  to_cilium="${1#*=}"; do_cilium=true; explicit_target=true; shift ;;
      --to-gvisor)    to_gvisor="$2";      do_gvisor=true; explicit_target=true; shift 2 ;;
      --to-gvisor=*)  to_gvisor="${1#*=}"; do_gvisor=true; explicit_target=true; shift ;;
      --to-betterleaks)   to_betterleaks="$2";      do_betterleaks=true; explicit_target=true; shift 2 ;;
      --to-betterleaks=*) to_betterleaks="${1#*=}"; do_betterleaks=true; explicit_target=true; shift ;;
      # App-phase options
      --to)           to="$2";          shift 2 ;;
      --to=*)         to="${1#*=}";     shift ;;
      --remote)       remote="$2";      shift 2 ;;
      --remote=*)     remote="${1#*=}"; shift ;;
      --rebuild)      do_rebuild=true;  shift ;;
      # Shared
      --dry-run)      dry_run=true;    shift ;;
      --force)        force=true;      shift ;;
      -y|--yes)       assume_yes=true; shift ;;
      -h|--help)      usage_upgrade ;;
      *) die "Unknown flag for 'upgrade': $1 (see 'sandbox upgrade --help')" ;;
    esac
  done

  # No target named at all -> the app (the safe default).
  ${explicit_target} || want_app=true
  # --infra is shorthand for every host component: the in-VM isolation stack
  # (k3s/Cilium/gVisor) plus the host-side betterleaks secret scanner.
  ${want_infra} && { do_k3s=true; do_cilium=true; do_gvisor=true; do_betterleaks=true; }

  local do_app="${want_app}"
  local do_infra=false
  if ${do_k3s} || ${do_cilium} || ${do_gvisor} || ${do_betterleaks}; then do_infra=true; fi

  # Reconstruct the infra selection as a flag list, for the case where the app
  # phase advances the code and we must re-exec the NEW CLI to run infra (so it
  # reads the freshly pulled setup/versions.sh pins — see below).
  local -a infra_passthru=()
  ${do_k3s}        && infra_passthru+=(--k3s)
  ${do_cilium}     && infra_passthru+=(--cilium)
  ${do_gvisor}     && infra_passthru+=(--gvisor)
  ${do_betterleaks} && infra_passthru+=(--betterleaks)
  [[ -n "${to_k3s}"         ]] && infra_passthru+=(--to-k3s "${to_k3s}")
  [[ -n "${to_cilium}"      ]] && infra_passthru+=(--to-cilium "${to_cilium}")
  [[ -n "${to_gvisor}"      ]] && infra_passthru+=(--to-gvisor "${to_gvisor}")
  [[ -n "${to_betterleaks}" ]] && infra_passthru+=(--to-betterleaks "${to_betterleaks}")
  ${force}      && infra_passthru+=(--force)
  ${assume_yes} && infra_passthru+=(-y)

  if ${do_app}; then
    # _upgrade_app_phase sets app_advanced and may `return 2` (non-git install)
    # without aborting under set -e, so capture its status via the || guard.
    local app_advanced=false app_rc=0
    _upgrade_app_phase || app_rc=$?

    if ${do_infra}; then
      if ${app_advanced}; then
        # The code just moved. bin/sandbox sources setup/versions.sh ONCE at
        # startup (see the top of this file), so this process still holds the
        # OLD pins. Re-exec the updated CLI so the infra phase applies the NEW
        # ones. The app-phase clean-tree/ff-only guards already ran.
        echo ""
        echo "App updated — re-executing to apply infra with the new pins..."
        exec "${SANDBOX_ROOT}/bin/sandbox" upgrade "${infra_passthru[@]}"
      fi
      # App unchanged (already current, or a tarball that can't self-update):
      # the in-memory pins already match the code, so run infra in-process.
      _upgrade_infra_phase
      return 0
    fi
    return "${app_rc}"
  fi

  _upgrade_infra_phase
}

# _upgrade_app_phase — fast-forward THIS checkout (the CLI itself) to the latest
# release tag. Reads cmd_upgrade's locals (to/remote/do_rebuild/dry_run/
# assume_yes/do_infra) via dynamic scope and sets `app_advanced` when it moves
# HEAD. Returns 0 on success (advanced or already current); returns 2 when the
# install is not a git checkout, so there is nothing to fast-forward.
_upgrade_app_phase() {
  local root="${SANDBOX_ROOT}"
  echo "=== sandbox upgrade (app / CLI) ==="

  # A released tarball has no .git — nothing to fast-forward. Point at the
  # download path; if infra is also queued, note it will still run below.
  if ! command -v git >/dev/null 2>&1 \
     || ! git -C "${root}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "This install isn't a git checkout, so 'upgrade' can't fast-forward the app."
    echo "  • To update the app: download the latest release and re-run setup:"
    echo "      https://github.com/samaritanark/agent-sandboxes/releases/latest"
    if ${do_infra}; then
      echo "  • Infrastructure will still be upgraded below."
    else
      echo "  • To move infrastructure only: sandbox upgrade --infra"
    fi
    return 2
  fi

  echo "Fetching releases from '${remote}'..."
  git -C "${root}" fetch --quiet --tags --prune "${remote}" \
    || die "Fetch from '${remote}' failed."

  # Target = explicit --to, else the highest semver v* tag (newest-first sort).
  local target="${to}"
  if [[ -z "${target}" ]]; then
    target="$(git -C "${root}" tag -l 'v*' --sort=-v:refname | head -1)"
  fi
  [[ -n "${target}" ]] || die "No release tags found on '${remote}'."

  # Resolve to a commit (separate decl so the command status isn't masked by
  # `local`). Fails cleanly if --to named a tag that doesn't exist.
  local tgt_c head_c
  tgt_c="$(git -C "${root}" rev-parse -q --verify "refs/tags/${target}^{commit}" 2>/dev/null)" \
    || die "Release tag '${target}' not found on '${remote}'."
  head_c="$(git -C "${root}" rev-parse HEAD)"

  echo "  Current: ${SANDBOX_VERSION}"
  echo "  Target:  ${target}"

  if [[ "${head_c}" == "${tgt_c}" ]]; then
    echo "Already at ${target}. Nothing to do."
    return 0
  fi

  # Clean fast-forward only: the target must be a descendant of HEAD. Otherwise
  # the checkout has diverged (local commits, or HEAD ahead of the release) —
  # refuse rather than merge or rewrite.
  if ! git -C "${root}" merge-base --is-ancestor "${head_c}" "${tgt_c}"; then
    die "Cannot fast-forward ${SANDBOX_VERSION} -> ${target}: this checkout has diverged. Reconcile with git, or re-clone."
  fi

  # TRUST: release tags are currently lightweight (created by 'gh release
  # create'), so there is no signed tag object to verify — best-effort check the
  # target commit's signature and WARN if it can't be confirmed. Once
  # release.yaml signs annotated tags with a pinned project key, replace this
  # with a hard gate via lib/vetting.sh's _vetting_verify_tag against a
  # config/release-signers trust root.
  if git -C "${root}" verify-commit "${tgt_c}" >/dev/null 2>&1; then
    echo "  Signature: verified"
  else
    warn "Could not verify ${target}'s signature locally (unsigned tag / signing key absent); proceeding on channel trust."
  fi

  if ${dry_run}; then
    echo "(dry run — no changes made)"
    return 0
  fi

  # Refuse on a dirty tree before mutating: a fast-forward won't touch local
  # edits, but updating around uncommitted work invites confusion (and git would
  # block a ff that must overwrite them anyway). Checked after the dry-run return
  # so --dry-run stays a read-only preview. Fail toward safe.
  if ! git -C "${root}" diff --quiet 2>/dev/null \
     || ! git -C "${root}" diff --cached --quiet 2>/dev/null; then
    die "Working tree at ${root} has uncommitted changes. Commit or stash them first."
  fi

  if ! ${assume_yes}; then
    printf 'Update app %s -> %s? [y/N] ' "${SANDBOX_VERSION}" "${target}"
    local reply; read -r reply
    [[ "${reply}" =~ ^[Yy] ]] || die "Aborted."
  fi

  # Fast-forward the current branch to the release commit — stays on-branch,
  # never rewrites, and the clean-tree guard above means no local edits are lost.
  git -C "${root}" merge --ff-only "${tgt_c}" \
    || die "Fast-forward to ${target} failed."
  app_advanced=true

  # Re-stamp so 'sandbox version'/'status' report the new identity (the runtime
  # never recomputes from git — see stamp_version_if_git in lib/platform.sh).
  stamp_version_if_git
  echo "Updated app to ${target}."

  # Images are built from this code; a code bump can leave them stale. Advise,
  # or rebuild now with --rebuild. (The rebuild runs the pre-update rebuild
  # logic against the freshly pulled Dockerfiles/build args, which is correct
  # for the common case; run 'sandbox rebuild' again if a release changed the
  # rebuild logic itself.)
  if ${do_rebuild}; then
    echo "Rebuilding agent images..."
    cmd_rebuild
  else
    echo "Agent images may be stale — rebuild when convenient: sandbox rebuild"
  fi
  return 0
}

# _upgrade_infra_phase — move the pinned host-level infra components forward:
# the in-VM isolation stack (k3s/Cilium/gVisor) and the host-side betterleaks
# secret scanner. Reads cmd_upgrade's locals (do_k3s/do_cilium/do_gvisor/
# do_betterleaks/to_*/force/assume_yes/dry_run) via dynamic scope.
_upgrade_infra_phase() {
  local platform
  platform="$(detect_platform)"

  # betterleaks target: explicit override, else the setup/versions.sh pin.
  local tgt_bl="${to_betterleaks:-${SANDBOX_BETTERLEAKS_VERSION}}"

  # betterleaks is a HOST-side helper, not part of the in-VM isolation stack:
  # it upgrades on any platform (including macOS, where the k3s/Cilium/gVisor
  # stack lives in the Lima VM and can't be moved in place), and swapping the
  # binary neither restarts k3s nor disturbs live sessions. So handle it up
  # front, before the macOS VM guard and the running-session guard that only
  # the cluster stack needs. install_betterleaks is idempotent — it no-ops when
  # the installed copy already satisfies the target.
  if ${do_betterleaks}; then
    local only_bl=true
    if ${do_k3s} || ${do_cilium} || ${do_gvisor}; then only_bl=false; fi

    echo "=== sandbox upgrade (betterleaks secret scanner) ==="
    local have_bl
    have_bl="$(command -v betterleaks >/dev/null 2>&1 \
      && betterleaks version 2>/dev/null | tr -d '[:space:]' || true)"
    infra_version_line "betterleaks" "${tgt_bl:-latest}" "${have_bl:-none}"

    if ${dry_run}; then
      if ${only_bl}; then echo "(dry run — no changes made)"; return 0; fi
      echo ""
    else
      (
        set -euo pipefail
        export SANDBOX_ROOT
        export SANDBOX_BETTERLEAKS_VERSION="${tgt_bl}"
        # shellcheck source=../setup/common.sh
        source "${SANDBOX_ROOT}/setup/common.sh"
        install_betterleaks
        record_infra_versions
      ) || die "betterleaks upgrade failed — see output above."
      if ${only_bl}; then
        stamp_version_if_git
        echo ""
        echo "=== upgrade complete ==="
        return 0
      fi
      echo ""
    fi
  fi

  # macOS: the isolation stack is inside the Lima VM. In-place VM upgrades are
  # out of scope for now — re-provisioning is the supported path.
  if [[ "${platform}" == "macos" ]]; then
    warn "On macOS the k3s/Cilium/gVisor stack runs inside the Lima VM."
    echo "  In-place VM upgrades aren't supported yet. To move the stack forward,"
    echo "  bump the pins in setup/versions.sh (or let Renovate open a PR), then"
    echo "  re-provision the VM:"
    echo ""
    echo "    limactl delete --force ${LIMA_VM_NAME:-sandbox-vm}"
    echo "    sandbox install"
    echo ""
    exit 1
  fi

  # Targets: explicit override, else the pin from setup/versions.sh.
  local tgt_k3s="${to_k3s:-${SANDBOX_K3S_VERSION}}"
  local tgt_cilium="${to_cilium:-${SANDBOX_CILIUM_VERSION}}"
  local tgt_gvisor="${to_gvisor:-${SANDBOX_GVISOR_RELEASE}}"

  echo "=== sandbox upgrade (host-level infra) ==="
  echo "Plan (target vs installed):"
  ${do_k3s}    && infra_version_line "k3s"    "${tgt_k3s}"    "$(infra_installed_k3s)"
  ${do_cilium} && infra_version_line "Cilium" "${tgt_cilium}" "$(infra_installed_cilium)"
  ${do_gvisor} && infra_version_line "gVisor" "${tgt_gvisor}" "$(infra_installed_gvisor)"
  echo ""

  if ${dry_run}; then
    echo "(dry run — no changes made)"
    return 0
  fi

  # Running-session guard: an upgrade restarts k3s and can blip the Cilium
  # datapath, which kills live agent sessions. Refuse unless forced.
  local pod_count
  pod_count="$(kubectl get pods -n "${SANDBOX_NAMESPACE}" --no-headers 2>/dev/null | wc -l | tr -d ' ')"
  pod_count="${pod_count:-0}"
  if [[ "${pod_count}" -gt 0 ]]; then
    if ! ${force}; then
      die "${pod_count} running session(s). An upgrade restarts k3s and can drop live sessions. Stop them ('sandbox stop' / 'sandbox cleanup'), or re-run with --force to override."
    fi
    warn "${pod_count} running session(s) will likely be disrupted by this upgrade (--force)."
  fi

  if ! ${assume_yes}; then
    printf 'Proceed with upgrade? [y/N] '
    local reply; read -r reply
    [[ "${reply}" =~ ^[Yy] ]] || die "Aborted."
  fi

  # Run the actual upgrade in a subshell so sourcing the setup scripts doesn't
  # leak their globals/functions into the CLI process. The setup installers are
  # reused verbatim (targets passed via the SANDBOX_*_VERSION env they read).
  (
    set -euo pipefail
    export SANDBOX_ROOT
    export SANDBOX_K3S_VERSION="${tgt_k3s}"
    export SANDBOX_CILIUM_VERSION="${tgt_cilium}"
    export SANDBOX_GVISOR_RELEASE="${tgt_gvisor}"
    # Keep the recorded manifest's betterleaks line consistent with what the
    # up-front betterleaks step installed (it ran outside this subshell).
    export SANDBOX_BETTERLEAKS_VERSION="${tgt_bl}"
    # shellcheck source=../setup/common.sh
    source "${SANDBOX_ROOT}/setup/common.sh"
    # shellcheck source=../setup/linux.sh
    source "${SANDBOX_ROOT}/setup/linux.sh"

    if ${do_k3s}; then
      echo "==> Upgrading k3s..."
      upgrade_k3s_linux
    fi
    if ${do_cilium}; then
      echo "==> Upgrading Cilium..."
      install_cilium_helm   # helm upgrade --install --version <target>
    fi
    if ${do_gvisor}; then
      echo "==> Upgrading gVisor..."
      install_gvisor_linux  # re-downloads the pinned runsc + shim
      echo "  Restarting k3s to load the new runsc..."
      sudo systemctl restart k3s
      wait_for_k3s 30
    fi

    # Persist what we moved to, so 'sandbox status' reflects it.
    record_infra_versions
  ) || die "Upgrade failed — see output above. The cluster may be partially upgraded; re-run to retry."

  # Keep `sandbox version` accurate now that the operator has refreshed their
  # install: re-embed the git-derived identity (no-op outside a git work tree).
  # SANDBOX_VERSION in this process was read at startup, so report the freshly
  # stamped value rather than the stale one.
  stamp_version_if_git
  local _stamped=""
  [[ -f "${SANDBOX_ROOT}/.version" ]] && \
    _stamped="$(awk -F= '$1=="VERSION"{print $2; exit}' "${SANDBOX_ROOT}/.version")"

  echo ""
  echo "=== upgrade complete ==="
  [[ -n "${_stamped}" ]] && echo "Version:     ${_stamped}"
  echo "Verify with: sandbox status"
}

###############################################################################
# cmd_configure_network — re-detect host network state and reconcile k3s/Cilium.
#
# Handles every kind of host-network drift in a single pass — primary/VPN
# interface name changes (VPN reconnect, dock swap) and primary IPv4 changes
# (DHCP lease, wifi SSID swap, or a WSL2 distro getting a fresh Hyper-V NAT
# address after a Windows reboot), including all of them at once. Applies the
# minimum restart needed; idempotent when nothing has drifted. See
# reconcile_host_network in lib/network.sh for the full ordering rationale.
#
# Linux only. The macOS-via-Lima case (VPN on macOS host, cluster inside
# Lima VM) is a different topology that this tool does not handle.
###############################################################################
cmd_configure_network() {
  local show_dns_only="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --show-dns)  show_dns_only="true" ;;
      --help|-h)
        cat <<EOF
sandbox configure-network — re-detect host network state and reconcile k3s/Cilium

USAGE:
  sandbox configure-network [--show-dns]

Run after a VPN reconnects or the host IP changes. Reconciles Cilium's device
list, the node InternalIP, and CoreDNS split-horizon DNS (so internal VPN-routed
names resolve via their dedicated servers instead of bouncing off a public
resolver). Idempotent when nothing has drifted.

OPTIONS:
  --show-dns   Print the CoreDNS split-horizon ConfigMap that would be applied
               (derived from systemd-resolved + ~/.sandbox/config.yaml) and
               exit without touching the cluster.
  --help       Show this help
EOF
        exit 0 ;;
      *) die "Unknown option: $1. Run 'sandbox configure-network --help' for usage." ;;
    esac
    shift
  done

  if [[ "$(detect_platform)" != "linux" ]]; then
    die "configure-network is Linux-only. On macOS the cluster runs inside the Lima VM and cannot see the host's VPN interfaces."
  fi

  if [[ "${show_dns_only}" == "true" ]]; then
    require_command jq "Install jq via your package manager."
    echo "==> CoreDNS split-horizon DNS that would be applied:"
    local zones
    zones="$(dns_effective_zones)"
    if [[ -z "${zones}" ]]; then
      echo "  (none — no VPN routing domains in systemd-resolved and no"
      echo "   internal_dns_zones in ${USER_SANDBOX_CONFIG})"
      return 0
    fi
    printf '%s\n' "${zones}" | render_split_dns_configmap
    return 0
  fi

  require_command kubectl "Install kubectl: https://kubernetes.io/docs/tasks/tools/"
  require_command helm "Install helm: https://helm.sh/docs/intro/install/"
  require_command jq "Install jq via your package manager."

  echo "==> Re-detecting host network state..."
  reconcile_host_network "${SANDBOX_KUBECONFIG}"
  echo "==> Reconciling CoreDNS split-horizon DNS..."
  sync_split_dns "${SANDBOX_KUBECONFIG}"
}

###############################################################################
# cmd_onboard — stage host-side agent OAuth state into ~/.sandbox/agent-home
###############################################################################
usage_onboard() {
  cat <<EOF
sandbox onboard — One-time host-to-sandbox credential staging

USAGE:
  sandbox onboard [OPTIONS]

OPTIONS:
  --agent <claude|codex|opencode|copilot|grok|all>  Limit to one agent (default: all)
  --skip-config                        Don't write ~/.sandbox/config.yaml
  --dry-run                            Report what would be done; copy nothing
  --force                              Overwrite already-staged files
  --help                               Show this help

WHAT IT DOES:
  For each detected agent, copies the host-side OAuth credential file and
  benign settings into ~/.sandbox/agent-home/<agent>/ so the first sandbox
  session uses already-authenticated tokens. Skips conversation history.
  Refuses to ingest long-lived API keys (PRINCIPLES.md rule 1) — for
  opencode, point users at 'sandbox secret' (Phase 4) instead.

  For codex, also ensures the staged config.toml sets
  sandbox_mode = "danger-full-access" — Codex's own bubblewrap sandbox
  can't start under gVisor and blocks apply_patch; the pod already
  provides isolation. Re-run any time to apply this to an existing
  agent-home (an operator's own sandbox_mode, if set, is left alone).

  Also writes a starter ~/.sandbox/config.yaml if absent.
EOF
  exit 0
}

cmd_onboard() {
  local opt_agent="all"
  local opt_dry_run="false"
  local opt_force="false"
  local opt_skip_config="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)         usage_onboard ;;
      --agent)           opt_agent="${2:?--agent requires a value}"; shift ;;
      --agent=*)         opt_agent="${1#--agent=}" ;;
      --dry-run)         opt_dry_run="true" ;;
      --force)           opt_force="true" ;;
      --skip-config)     opt_skip_config="true" ;;
      *)                 die "Unknown option: $1. Run 'sandbox onboard --help' for usage." ;;
    esac
    shift
  done

  case "${opt_agent}" in
    claude|codex|opencode|copilot|grok|all) ;;
    *) die "--agent must be one of: claude, codex, opencode, copilot, grok, all" ;;
  esac

  if [[ "${opt_dry_run}" == "true" ]]; then
    echo "==> sandbox onboard (dry-run)"
  else
    echo "==> sandbox onboard"
  fi
  echo

  # Warn (don't fail) on forbidden host env vars. They will never enter
  # the sandbox via this command — but the operator deserves a heads-up
  # that whatever's set won't be carried forward.
  local _forbidden_count
  _forbidden_count="$(warn_forbidden_env)"
  if [[ "${_forbidden_count}" -gt 0 ]]; then
    echo
  fi

  echo "==> Staging agent credentials"
  local -a agents=()
  if [[ "${opt_agent}" == "all" ]]; then
    agents=(claude codex opencode copilot grok)
  else
    agents=("${opt_agent}")
  fi

  local a
  for a in "${agents[@]}"; do
    onboard_agent "${a}" "${opt_dry_run}" "${opt_force}"
  done

  if [[ "${opt_skip_config}" != "true" ]]; then
    echo
    echo "==> Starter user config"
    write_starter_user_config "${opt_dry_run}" "${opt_force}"
  fi

  echo
  if [[ "${opt_dry_run}" == "true" ]]; then
    echo "Dry-run complete; nothing was written."
  else
    echo "Onboard complete. Run 'sandbox run --agent <name>' to launch a session."
  fi
}

###############################################################################
# cmd_allow — hot-reload a running session's allowed-domain list
###############################################################################
usage_allow() {
  cat <<EOF
sandbox allow — Add domains to a running session's egress allowlist

USAGE:
  sandbox allow <session-id> --add-domain <DOMAIN> [--add-domain <DOMAIN> ...]
  sandbox allow --help

WHAT IT DOES:
  Regenerates the session's CiliumNetworkPolicy with the existing
  allowed-domain list PLUS the supplied --add-domain values and applies
  it. Because Cilium identifies the policy by name, the apply is a
  patch — the live pod is NOT restarted and DNS/HTTPS connections
  in flight are preserved. Updates session.json's allowed_domains and
  emits an audit event.

  Every --add-domain still passes through the org-level (and overlay,
  if configured) blocked-destinations check. The session pod must
  still be running.

  Add-only by design. Removing a domain from a live session can break
  in-flight requests in subtle ways and weakens the audit trail; if
  you need a narrower allowlist, stop the session and re-run with the
  intended set.

EXAMPLES:
  # Add a single domain
  sandbox allow ses-20260527-...-a7b3 --add-domain go.private.example.com

  # Add several at once
  sandbox allow ses-20260527-...-a7b3 \\
      --add-domain artifactory.example.com \\
      --add-domain pypi.private.example.com
EOF
  exit 0
}

cmd_allow() {
  if [[ $# -eq 0 ]]; then
    usage_allow
  fi

  local session_id=""
  local -a opt_add_domains=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)         usage_allow ;;
      --add-domain)      opt_add_domains+=("${2:?--add-domain requires a value}"); shift ;;
      --add-domain=*)    opt_add_domains+=("${1#--add-domain=}") ;;
      -*)                die "Unknown option for 'allow': $1" ;;
      *)
        if [[ -n "${session_id}" ]]; then
          die "Unexpected extra argument: $1 (only one session-id allowed)."
        fi
        session_id="$1"
        ;;
    esac
    shift
  done

  [[ -n "${session_id}" ]] \
    || die "Usage: sandbox allow <session-id> --add-domain <DOMAIN> [...]"
  [[ "${#opt_add_domains[@]}" -gt 0 ]] \
    || die "At least one --add-domain is required."

  local log_dir="${SANDBOX_LOGS_DIR}/${session_id}"
  local session_json="${log_dir}/session.json"
  [[ -f "${session_json}" ]] \
    || die "No session.json for ${session_id} at ${log_dir/#${HOME}/\~}/."

  # Validate each new domain against the blocked-destinations list
  # (and overlay's, if configured). Same code path as --allow-domain.
  # Runs BEFORE the cluster check so a blocked domain is rejected
  # without needing a live cluster.
  local d
  for d in "${opt_add_domains[@]}"; do
    check_domain_not_blocked "${d}"
  done
  # The regenerated policy re-renders egressDeny from blocked_cidrs, so a
  # malformed entry would break the hot-reload too — validate it first.
  check_blocked_cidrs_valid

  # Verify the pod is still alive. Hot-reload against a torn-down session
  # would leave session.json in a state that disagrees with reality.
  ensure_cluster_ready
  local pod_name
  pod_name="$(resolve_pod_name "${session_id}")"
  if ! kubectl get pod -n "${SANDBOX_NAMESPACE}" "${pod_name}" \
       >/dev/null 2>&1; then
    die "Pod ${pod_name} not running — hot-reload only works on live sessions. (Use 'sandbox run' to start a new session with the wider allowlist.)"
  fi

  # Read session metadata needed to rebuild the policy.
  local agent tier kube_api_cidr kube_api_port
  agent="$(jq -r '.agent' "${session_json}")"
  tier="$(jq -r '.tier' "${session_json}")"
  kube_api_cidr="$(jq -r '.kube_api_cidr // ""' "${session_json}")"
  kube_api_port="$(jq -r '.kube_api_port // ""' "${session_json}")"

  # Compute the new "extras" list = (existing allowed_domains ∪ new) –
  # (agent_domains ∪ tier_domains). build_cilium_policy re-adds agent +
  # tier on top of whatever extras we pass, so we strip them out here
  # to avoid duplicate matchName entries in the rendered YAML.
  local agent_dom_json tier_dom_json new_arr_json
  agent_dom_json="$(get_agent_domains "${agent}" | jq -R . | jq -s -c .)"
  tier_dom_json="$(get_tier_domains "${tier}" | jq -R . | jq -s -c .)"
  new_arr_json="$(printf '%s\n' "${opt_add_domains[@]}" | jq -R . | jq -s -c .)"

  # Merged full set (for session.json) and extras-only (for the policy).
  local merged_full_json merged_extras_json
  merged_full_json="$(jq -c -n \
    --argjson cur "$(jq '.allowed_domains' "${session_json}")" \
    --argjson new "${new_arr_json}" \
    '($cur + $new) | unique')"
  merged_extras_json="$(jq -c -n \
    --argjson full "${merged_full_json}" \
    --argjson agent "${agent_dom_json}" \
    --argjson tier "${tier_dom_json}" \
    '($full - $agent - $tier)')"

  # Detect the no-op case (every --add-domain was already allowed) so
  # the operator gets a clear "nothing to do" rather than a silent
  # kubectl apply that changes nothing.
  local new_count
  new_count="$(jq -r '. | length' <<<"${merged_full_json}")"
  local existing_count
  existing_count="$(jq -r '.allowed_domains | length' "${session_json}")"
  if [[ "${new_count}" -eq "${existing_count}" ]]; then
    echo "All requested domains are already in the allowlist; nothing to do."
    return 0
  fi

  # Rebuild and apply the policy. Same name as the original → kubectl
  # apply is a patch; the running pod is not disturbed.
  local -a extras_arr=()
  read_into_array extras_arr < <(jq -r '.[]' <<<"${merged_extras_json}")

  # Phase 5: restore the session's dependency reach from session.json so the
  # hot-reload preserves the per-dependency toEndpoints + cluster-local DNS
  # rules. Without this, regenerating the policy would silently sever the
  # session from its declared dependencies. build_cilium_policy reads the
  # SESSION_DEP_ENDPOINTS global ("resource_name port" per dependency).
  SESSION_DEP_ENDPOINTS=()
  read_into_array SESSION_DEP_ENDPOINTS < <(jq -r \
    '(.dependencies // [])[] | "\(.resource_name) \(.port)"' "${session_json}" 2>/dev/null || true)

  echo "==> Regenerating CiliumNetworkPolicy for ${session_id}..."
  local policy_yaml
  policy_yaml="$(build_cilium_policy \
    "${session_id}" \
    "${agent}" \
    "${tier}" \
    "${kube_api_cidr}" \
    "${kube_api_port}" \
    "${extras_arr[@]+"${extras_arr[@]}"}")"
  SESSION_DEP_ENDPOINTS=()
  echo "${policy_yaml}" | kubectl apply -f - >/dev/null
  echo "  Applied: $(( new_count - existing_count )) new domain(s)."

  # Update session.json's allowed_domains and append an audit event.
  local tmp_json
  tmp_json="$(mktemp)"
  jq --argjson full "${merged_full_json}" \
    '.allowed_domains = $full' \
    "${session_json}" > "${tmp_json}"
  mv "${tmp_json}" "${session_json}"

  local added_csv
  added_csv="$(jq -r '. | join(",")' <<<"${new_arr_json}")"
  audit_log_event "${log_dir}" "allowlist-extended" "Added domains: ${added_csv}"

  echo
  echo "Allowlist updated for ${session_id}."
  echo "  Full allowed-domain count: ${new_count}"
}

###############################################################################
# cmd_mask — manage per-repo file masking (masked_paths in .sandbox/config.yaml)
###############################################################################
usage_mask() {
  cat <<EOF
sandbox mask — Manage per-repo file masking

USAGE:
  sandbox mask add --repo <PATH> <RELPATH>...
  sandbox mask list --repo <PATH>
  sandbox mask --help

Files in a Tier 2/3 workspace are mounted read-write for the agent. A
built-in set of root-level paths (.env, .npmrc, kubeconfig, .kube/,
*-openrc.sh, ...) is replaced with empty overlays so the agent can't read
them. 'mask add' extends that set per-repo: each RELPATH (relative to the
repo root) is recorded under masked_paths: in <repo>/.sandbox/config.yaml
and mounted as an empty overlay at launch.

This is what 'sandbox run' suggests when its betterleaks scan finds a
secret in a file the mask would not otherwise hide.

EXAMPLES:
  # Mask a nested config file flagged by the secret gate
  sandbox mask add --repo ~/repos/app config/prod/secrets.yaml

  # Show the effective masked set (built-in + configured) for a repo
  sandbox mask list --repo ~/repos/app
EOF
  exit 0
}

cmd_mask() {
  if [[ $# -eq 0 ]]; then
    usage_mask
  fi

  local sub="$1"
  shift

  case "${sub}" in
    --help|-h|help)
      usage_mask
      ;;
    add)
      local repo=""
      local -a relpaths=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --repo)    repo="${2:?--repo requires a value}"; shift ;;
          --repo=*)  repo="${1#--repo=}" ;;
          --help|-h) usage_mask ;;
          -*)        die "Unknown option for 'mask add': $1" ;;
          *)         relpaths+=("$1") ;;
        esac
        shift
      done
      [[ -n "${repo}" ]] || die "Usage: sandbox mask add --repo <PATH> <RELPATH>..."
      [[ "${#relpaths[@]}" -gt 0 ]] || die "mask add: at least one RELPATH is required."
      repo="${repo/#\~/${HOME}}"
      validate_repo_path "${repo}"

      local config_file="${repo}/.sandbox/config.yaml"
      local rel
      for rel in "${relpaths[@]}"; do
        # Reject absolute paths and parent-escapes — masks are repo-relative.
        if [[ "${rel}" == /* ]] || [[ "${rel}" == ../* ]] || [[ "${rel}" == */../* ]]; then
          die "mask add: RELPATH must be relative to the repo root and inside it: ${rel}"
        fi
        if [[ ! -e "${repo}/${rel}" ]]; then
          warn "Path does not exist in repo (masking it anyway): ${rel}"
        elif [[ ! -f "${repo}/${rel}" ]]; then
          die "mask add: only regular files can be masked (found a non-file): ${rel}"
        fi
        config_add_masked_path "${config_file}" "${rel}"
        echo "Masked '${rel}' in $(basename "${repo}") (${config_file/#${HOME}/\~})."
      done
      ;;
    list)
      local repo=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --repo)    repo="${2:?--repo requires a value}"; shift ;;
          --repo=*)  repo="${1#--repo=}" ;;
          --help|-h) usage_mask ;;
          -*)        die "Unknown option for 'mask list': $1" ;;
          *)         die "Unexpected argument for 'mask list': $1" ;;
        esac
        shift
      done
      [[ -n "${repo}" ]] || die "Usage: sandbox mask list --repo <PATH>"
      repo="${repo/#\~/${HOME}}"
      validate_repo_path "${repo}"

      echo "Built-in masked paths (root-level):"
      local p
      for p in "${MASKED_FILE_PATHS[@]}"; do echo "  ${p}"; done
      echo "  ${MASKED_DIR_PATH}/  (directory)"
      echo "  ${MASKED_OPENRC_PATTERN}"
      echo ""
      echo "Configured masked_paths for $(basename "${repo}"):"
      local any=false
      while IFS= read -r p; do
        [[ -z "${p}" ]] && continue
        any=true
        if [[ -f "${repo}/${p}" ]]; then
          echo "  ${p}"
        else
          echo "  ${p}  (not present in repo)"
        fi
      done < <(load_repo_masked_paths "${repo}")
      [[ "${any}" == false ]] && echo "  (none)"
      ;;
    *)
      die "Unknown 'mask' subcommand: ${sub}. Run 'sandbox mask --help'."
      ;;
  esac
}

###############################################################################
# cmd_exceptions — manage per-repo accepted secret findings (accepted_secrets in
# .sandbox/config.yaml), the reviewed-false-positive accept-list for the gate.
###############################################################################
usage_exceptions() {
  cat <<EOF
sandbox exceptions — Record reviewed false positives for the secret gate

USAGE:
  sandbox exceptions add --repo <PATH> <PATH:RULE:LINE>... [--reason <TEXT>]
  sandbox exceptions list --repo <PATH>
  sandbox exceptions --help

The Tier 2/3 secret gate refuses to launch when betterleaks finds a secret in a
file the mask would not hide. When a finding is a reviewed false positive, record
it here instead of masking the whole file or accepting every secret at launch.
Each entry is a fingerprint 'RELPATH:RULE:LINE:HASH' — the finding's path, rule,
line, and a short SHA-256 of the matched value — appended under accepted_secrets:
in <repo>/.sandbox/config.yaml.

The gate honours these ONLY when the repo is VETTED (see 'sandbox vet'): the
signed attestation covers this whole tree, including this list, so accepting a
finding carries a reviewer's cryptographic sign-off rather than the say-so of an
unreviewed workspace. Because the fingerprint pins the matched value, replacing
the secret at that location changes the hash and the finding blocks again.

'exceptions add' names findings the way the gate prints them (RELPATH, RULE, LINE);
it re-scans to resolve and record the value hash, so a matching finding must
exist in the current tree. The written entry is plain text — a reviewer can add
or audit one by hand.

  --repo <PATH>       Repository whose accepted_secrets: list to edit/inspect.
  --reason <TEXT>     Optional note, stored as a YAML comment beside the entry.
  --help              Show this help

EXAMPLES:
  # Accept a specific finding the gate flagged (path, rule, line as printed)
  sandbox exceptions add --repo ~/repos/app \\
      deploy/values.yaml:generic-api-key:155 --reason "sealed secret, reviewed AH"

  # Show the recorded accept-list for a repo
  sandbox exceptions list --repo ~/repos/app
EOF
  exit 0
}

cmd_exceptions() {
  if [[ $# -eq 0 ]]; then
    usage_exceptions
  fi

  local sub="$1"
  shift

  case "${sub}" in
    --help|-h|help)
      usage_exceptions
      ;;
    add)
      local repo="" reason=""
      local -a specs=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --repo)     repo="${2:?--repo requires a value}"; shift ;;
          --repo=*)   repo="${1#--repo=}" ;;
          --reason)   reason="${2:?--reason requires a value}"; shift ;;
          --reason=*) reason="${1#--reason=}" ;;
          --help|-h)  usage_exceptions ;;
          -*)         die "Unknown option for 'exceptions add': $1" ;;
          *)          specs+=("$1") ;;
        esac
        shift
      done
      [[ -n "${repo}" ]] || die "Usage: sandbox exceptions add --repo <PATH> <PATH:RULE:LINE>..."
      [[ "${#specs[@]}" -gt 0 ]] || die "exceptions add: at least one PATH:RULE:LINE is required."
      repo="${repo/#\~/${HOME}}"
      validate_repo_path "${repo}"

      command -v betterleaks &>/dev/null || die "exceptions add: betterleaks is required to resolve a finding's value hash, but it was not found on PATH."
      command -v jq &>/dev/null || die "exceptions add: jq is required but was not found on PATH."

      local config_file="${repo}/.sandbox/config.yaml"
      local spec relpath rule line rest rc entries added fp
      for spec in "${specs[@]}"; do
        # Right-split PATH:RULE:LINE so a ':' in RELPATH is tolerated: LINE is the
        # last field, RULE the next, RELPATH everything before.
        line="${spec##*:}"; rest="${spec%:*}"
        rule="${rest##*:}"; relpath="${rest%:*}"
        if [[ "${rest}" != *:* ]] || [[ -z "${relpath}" ]] || [[ -z "${rule}" ]] || [[ ! "${line}" =~ ^[0-9]+$ ]]; then
          die "exceptions add: expected PATH:RULE:LINE (e.g. deploy/values.yaml:generic-api-key:155), got: ${spec}"
        fi
        if [[ "${relpath}" == /* ]] || [[ "${relpath}" == ../* ]] || [[ "${relpath}" == */../* ]]; then
          die "exceptions add: PATH must be relative to the repo root and inside it: ${relpath}"
        fi

        # Capture the resolver's status without set -e aborting on its non-zero
        # (not-found / scan-failed) returns, which we handle explicitly below.
        rc=0
        entries="$(leakscan_fingerprints_for "${repo}" "${relpath}" "${rule}" "${line}")" || rc=$?
        case "${rc}" in
          0) : ;;
          1) die "exceptions add: no ${rule} finding at ${relpath}:${line} in the current tree. Run 'sandbox run' (or 'sandbox check') to see the gate's findings, and copy the RELPATH:RULE:LINE it prints." ;;
          2) die "exceptions add: betterleaks failed to scan ${repo}. Nothing was recorded." ;;
          *) die "exceptions add: betterleaks/jq unavailable." ;;
        esac

        added=0
        while IFS= read -r fp; do
          [[ -z "${fp}" ]] && continue
          config_add_accepted_secret "${config_file}" "${fp}" "${reason}"
          echo "Accepted ${fp} in $(basename "${repo}") (${config_file/#${HOME}/\~})."
          added=$((added + 1))
        done <<<"${entries}"
        [[ "${added}" -gt 0 ]] || die "exceptions add: could not fingerprint ${spec}."
      done
      echo ""
      echo "NOTE: the gate honours these only once the repo is vetted ('sandbox vet --repo ${repo}')."
      ;;
    list)
      local repo=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --repo)    repo="${2:?--repo requires a value}"; shift ;;
          --repo=*)  repo="${1#--repo=}" ;;
          --help|-h) usage_exceptions ;;
          -*)        die "Unknown option for 'exceptions list': $1" ;;
          *)         die "Unexpected argument for 'exceptions list': $1" ;;
        esac
        shift
      done
      [[ -n "${repo}" ]] || die "Usage: sandbox exceptions list --repo <PATH>"
      repo="${repo/#\~/${HOME}}"
      validate_repo_path "${repo}"

      echo "Accepted secret findings for $(basename "${repo}"):"
      local any=false fp
      while IFS= read -r fp; do
        [[ -z "${fp}" ]] && continue
        any=true
        echo "  ${fp}"
      done < <(load_repo_accepted_secrets "${repo}")
      [[ "${any}" == false ]] && echo "  (none)"
      ;;
    *)
      die "Unknown 'exceptions' subcommand: ${sub}. Run 'sandbox exceptions --help'."
      ;;
  esac
}

###############################################################################
# cmd_secret — manage host-side secret store, injected per-session by profile
###############################################################################
usage_secret() {
  cat <<EOF
sandbox secret — Manage host-side secrets injected by profile declaration

USAGE:
  sandbox secret set <NAME> [--from-file PATH | --from-env[=VAR]]
  sandbox secret list
  sandbox secret delete <NAME>
  sandbox secret --help

The store lives at ~/.sandbox/secrets/ (mode 0600 per file). Names must be
valid env-var identifiers — [A-Z_][A-Z0-9_]* — because the NAME is the
env-var the agent sees inside the pod when a profile injects it.

PROFILE INJECTION:
  Profiles list secrets to inject under 'secrets:' (see Phase 2 docs):

      # ~/.sandbox/profiles/dev-app.yaml
      tier: 2
      secrets:
        - JIRA_PAT
        - GITEA_TOKEN

  At 'sandbox run --profile dev-app' time, those values are read from
  the host store and bundled into ONE session-scoped K8s Secret
  (session-secrets-<id>). The pod gets them via envFrom: secretRef so
  each declared name lands as a container env var. The Secret is
  deleted on teardown — secrets never persist in the cluster across
  sessions (PRINCIPLES.md rule 2).

EXAMPLES:
  # Pipe a token in
  printf '%s' 'abcd1234' | sandbox secret set JIRA_PAT

  # From a host env var with the same name (--from-env defaults to NAME)
  sandbox secret set JIRA_PAT --from-env

  # From a differently-named host env var
  sandbox secret set JIRA_PAT --from-env=JIRA_PROD_TOKEN

  # From a file
  sandbox secret set GITEA_TOKEN --from-file ~/.gitea-token

  # List (names + sizes + mtimes; values are never printed)
  sandbox secret list

  # Remove
  sandbox secret delete JIRA_PAT
EOF
  exit 0
}

usage_vet() {
  cat <<EOF
sandbox vet — Attest that a repo is cleared for use with an AI agent

USAGE:
  sandbox vet --repo <PATH> [--message <MSG>] [--yes]
  sandbox vet --status --repo <PATH>
  sandbox vet --help

A trusted reviewer signs a git tag at the repo's current HEAD to record that
they reviewed that exact tree and cleared it for agent use. 'sandbox run'
consults this attestation before a Tier 2/3 launch: with 'vetting: required'
(in ~/.sandbox/config.yaml or a team overlay) a repo without a current,
verified attestation is refused.

The signature is verified host-side against an operator-held trust root — an
SSH allowed_signers file by default (vetting_trust_root:), or a GnuPG home when
vetting_trust_format: gpg. The tag is named 'agent-vetted/<sha>'. A dirty
working tree is refused: an attestation covers a commit, not uncommitted edits.

If the repo records secret exceptions ('sandbox exceptions'), signing blesses
them: the secret gate honors that list only on a vetted repo, so before signing
'vet' lists the finding(s) the agent would then be able to read and asks you to
acknowledge them. Use --yes to acknowledge non-interactively (e.g. in CI).

  --repo <PATH>       Repository to attest (or inspect with --status).
  --status            Print the repo's current vetting state instead of signing.
  --message <MSG>     Tag message (default: "vetted for agent use").
  --yes, -y           Acknowledge any recorded secret exceptions without prompting.
  --help              Show this help

EXAMPLES:
  # Attest the current HEAD, then push the tag so others can verify
  sandbox vet --repo ~/repos/app
  git -C ~/repos/app push origin agent-vetted/\$(git -C ~/repos/app rev-parse HEAD)

  # Check whether a repo would pass the gate
  sandbox vet --status --repo ~/repos/app
EOF
  exit 0
}

cmd_vet() {
  if [[ $# -eq 0 ]]; then
    usage_vet
  fi

  local action="attest" repo="" msg="vetted for agent use" assume_yes="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h|help) usage_vet ;;
      --status)       action="status" ;;
      --repo)         repo="${2:?--repo requires a value}"; shift ;;
      --repo=*)       repo="${1#--repo=}" ;;
      --message)      msg="${2:?--message requires a value}"; shift ;;
      --message=*)    msg="${1#--message=}" ;;
      --yes|-y)       assume_yes="true" ;;
      -*)             die "Unknown option for 'vet': $1" ;;
      *)              die "Unexpected argument for 'vet': $1" ;;
    esac
    shift
  done

  [[ -n "${repo}" ]] || die "Usage: sandbox vet --repo <PATH> [--status] [--message <MSG>]"
  repo="${repo/#\~/${HOME}}"
  validate_repo_path "${repo}"

  if [[ "${action}" == "status" ]]; then
    local line status f2 f3 f4
    line="$(vetting_status_repo "${repo}")"
    IFS=$'\t' read -r status f2 f3 f4 <<<"${line}"
    case "${status}" in
      vetted)
        echo "vetted:   ${repo}"
        echo "  HEAD:   ${f2}"
        echo "  tag:    ${f3}"
        echo "  signer: ${f4:-unknown}"
        ;;
      unvetted)
        echo "UNVETTED: ${repo}"
        echo "  HEAD:   ${f2}"
        echo "  reason: ${f3}"
        ;;
      dirty)
        echo "DIRTY:    ${repo} (HEAD ${f2})"
        echo "  Commit or stash the working tree, then attest."
        ;;
      error)
        echo "ERROR:    ${f2}" >&2
        exit 1
        ;;
      *)
        echo "${status}: ${f2}"
        ;;
    esac
    return 0
  fi

  vetting_attest_repo "${repo}" "${msg}" "${assume_yes}"
}

cmd_secret() {
  if [[ $# -eq 0 ]]; then
    usage_secret
  fi

  local sub="$1"
  shift

  case "${sub}" in
    --help|-h|help)
      usage_secret
      ;;
    set)
      # _USE_DEFAULT is the sentinel for "--from-env" with no argument —
      # resolved to the secret name after the parse loop, once `name` is
      # known. --from-env=VAR is the explicit form; the bare `--from-env VAR`
      # space form is intentionally NOT supported (ambiguous with the
      # secret-name positional; the = form is unambiguous).
      local name="" from_file="" from_env=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from-file)   from_file="${2:?--from-file requires a path}"; shift ;;
          --from-file=*) from_file="${1#--from-file=}" ;;
          --from-env)    from_env="_USE_DEFAULT" ;;
          --from-env=*)  from_env="${1#--from-env=}" ;;
          --help|-h)     usage_secret ;;
          -*)            die "Unknown option for 'secret set': $1" ;;
          *)
            if [[ -n "${name}" ]]; then
              die "Unexpected extra argument: $1"
            fi
            name="$1"
            ;;
        esac
        shift
      done
      [[ -n "${name}" ]] || die "Usage: sandbox secret set <NAME> [--from-file PATH | --from-env[=VAR]]"
      secret_validate_name "${name}"
      if [[ -n "${from_file}" ]] && [[ -n "${from_env}" ]]; then
        die "secret set: --from-file and --from-env are mutually exclusive."
      fi
      if [[ -n "${from_file}" ]]; then
        secret_set_from_file "${name}" "${from_file/#\~/${HOME}}"
        echo "Stored secret '${name}' from ${from_file}."
      elif [[ -n "${from_env}" ]]; then
        # Resolve _USE_DEFAULT to the secret name — common case where the
        # host env var is named the same as the secret it populates.
        [[ "${from_env}" == "_USE_DEFAULT" ]] && from_env="${name}"
        secret_set_from_env "${name}" "${from_env}"
        echo "Stored secret '${name}' from \$${from_env}."
      else
        if [[ -t 0 ]]; then
          echo "Reading secret value from stdin. End with EOF (Ctrl-D)." >&2
        fi
        secret_set_from_stdin "${name}"
        echo "Stored secret '${name}'."
      fi
      ;;
    list)
      local count=0
      while IFS= read -r line; do
        if [[ -z "${line}" ]]; then continue; fi
        if [[ "${count}" -eq 0 ]]; then
          printf '%-32s  %12s  %s\n' "NAME" "SIZE" "UPDATED"
        fi
        echo "${line}"
        (( count++ )) || true
      done < <(secret_list)
      if [[ "${count}" -eq 0 ]]; then
        echo "No secrets in ${SECRETS_STORE_DIR/#${HOME}/\~}/."
        echo "Add one with: sandbox secret set <NAME>"
      fi
      ;;
    delete|rm|remove)
      [[ $# -ge 1 ]] || die "Usage: sandbox secret delete <NAME>"
      local name="$1"
      secret_validate_name "${name}"
      if secret_exists "${name}"; then
        secret_delete "${name}"
        echo "Deleted secret '${name}'."
      else
        echo "Secret '${name}' is not in the store; nothing to delete." >&2
      fi
      ;;
    *)
      die "Unknown 'secret' subcommand: ${sub}. Run 'sandbox secret --help'."
      ;;
  esac
}

###############################################################################
# cmd_link — link a git-backed team overlay and keep it pinned
###############################################################################
usage_link() {
  cat <<EOF
sandbox link — Link a git-backed team overlay (profiles, policies, catalogue)

USAGE:
  sandbox link <GIT-URL> [--name <NAME>] [--ref <TAG|BRANCH|COMMIT>]
  sandbox link status
  sandbox link sync [--ref <TAG|BRANCH|COMMIT>]
  sandbox link unlink [--keep-clone] [--yes]
  sandbox link --help

An overlay is a directory a team version-controls (see
examples/overlay-template/) that layers ADDITIONAL profiles, blocked
destinations, a vetted MCP/service catalogue, and CA certs on top of the
org install. 'link' clones that (typically private) repo into
~/.sandbox/overlays/<name>/, PINS it to a ref, validates its shape, and
points ~/.sandbox/config.yaml's 'overlay:' key at it.

Overlays are additive-only on the safety side: nothing in one can weaken
the org's controls or the tier model (enforced at consume time — see
PRINCIPLES.md, "Default-deny egress").

A link never advances on its own. 'sandbox run' does a cached, rate-limited
fetch and only HINTS when the overlay is behind its ref; 'sandbox link sync'
is the one deliberate step that moves the checked-out commit — it shows a
diff of what changes and re-validates before applying.

LINK OPTIONS:
  --name <NAME>   Directory name under ~/.sandbox/overlays/ (default: derived
                  from the repo URL). Letters, digits, '.', '_', '-'.
  --ref <REF>     Tag, branch, or commit to pin. Default: the remote's
                  default branch. sync tracks this ref until you change it.

SYNC OPTIONS:
  --ref <REF>     Change the pinned ref before advancing to its tip.

UNLINK OPTIONS:
  --keep-clone    Leave the cloned directory on disk; only clear the pointer.
  --yes, -y       Don't prompt for confirmation.

ENV:
  SANDBOX_NO_LINK_CHECK=1   Disable the run-path behind-ref check (CI/air-gap).

EXAMPLES:
  sandbox link git@github.com:acme/sandbox-overlay.git --ref v1.4.0
  sandbox link status
  sandbox link sync --ref v1.5.0
  sandbox link unlink
EOF
  exit 0
}

# _link_clone — clone a new git-backed overlay and wire the pointer.
_link_clone() {
  local url="" opt_name="" opt_ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)  usage_link ;;
      --name)     opt_name="${2:?--name requires a value}"; shift ;;
      --name=*)   opt_name="${1#--name=}" ;;
      --ref)      opt_ref="${2:?--ref requires a value}"; shift ;;
      --ref=*)    opt_ref="${1#--ref=}" ;;
      -*)         die "Unknown option for 'link': $1. Run 'sandbox link --help'." ;;
      *)          [[ -z "${url}" ]] || die "Unexpected argument: $1"; url="$1" ;;
    esac
    shift
  done
  [[ -n "${url}" ]] || die "Usage: sandbox link <GIT-URL> [--name <NAME>] [--ref <REF>]"
  _link_require_git

  if link_is_active; then
    die "A link is already active ($(link_url_config)). Run 'sandbox link unlink' first, or 'sandbox link sync' to update it."
  fi

  local name="${opt_name}"
  if [[ -z "${name}" ]]; then
    name="$(link_name_from_url "${url}")"
    [[ -n "${name}" ]] || die "Could not derive a link name from '${url}'. Pass --name <NAME>."
  fi
  link_is_valid_name "${name}" \
    || die "Invalid link name '${name}'. Use letters, digits, '.', '_', '-'; no '/', no leading '.'."

  local dir; dir="$(link_managed_dir "${name}")"
  [[ -e "${dir}" ]] && die "${dir/#${HOME}/\~} already exists. Choose another --name or remove it."

  # Warn (don't block) if the operator already had a hand-set overlay pointer —
  # linking takes over that pointer.
  local existing_overlay
  existing_overlay="$(extract_yaml_scalar_from_file "${USER_SANDBOX_CONFIG}" overlay)"
  [[ -n "${existing_overlay}" ]] \
    && warn "existing 'overlay: ${existing_overlay}' will be repointed at the linked clone."

  echo "==> Cloning ${url}"
  mkdir -p "${LINK_OVERLAYS_DIR}"
  if ! git clone --quiet "${url}" "${dir}"; then
    rm -rf "${dir}"
    die "git clone failed. Check the URL and your git credentials for private repos."
  fi

  local ref="${opt_ref}"
  if [[ -n "${ref}" ]]; then
    if ! git -C "${dir}" checkout --quiet "${ref}" 2>/dev/null; then
      rm -rf "${dir}"
      die "ref '${ref}' not found in ${url}."
    fi
  else
    ref="$(git -C "${dir}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)"
  fi

  local commit; commit="$(_link_head_commit "${dir}")"

  echo "==> Validating overlay shape"
  if ! link_validate_shape "${dir}"; then
    rm -rf "${dir}"
    die "overlay at '${url}' (${ref}) failed validation; nothing was linked."
  fi

  link_write_config "${dir}" "${url}" "${ref}" "${commit}"
  echo "Linked overlay '${name}' → ${dir/#${HOME}/\~}"
  echo "  ref:    ${ref}"
  echo "  commit: ${commit:0:12}"
  echo "  pointer written to the 'overlay:' key in ${USER_SANDBOX_CONFIG/#${HOME}/\~}"
}

# _link_status — show the active link and whether it's behind its ref.
_link_status() {
  case "${1:-}" in --help|-h) usage_link ;; "") ;; *) die "Unexpected argument: $1" ;; esac
  if ! link_is_active; then
    echo "No linked overlay. Link one with: sandbox link <GIT-URL>"
    return 0
  fi
  _link_require_git

  local url ref dir
  url="$(link_url_config)"
  ref="$(link_ref_config)"
  dir="$(link_active_dir)"

  echo "Linked overlay"
  printf "  %-8s %s\n" "url:" "${url}"
  printf "  %-8s %s\n" "ref:" "${ref}"
  printf "  %-8s %s\n" "commit:" "$(link_commit_config)"
  if [[ -z "${dir}" ]]; then
    warn "recorded overlay pointer is not a git clone; the link record may be stale."
    return 0
  fi
  printf "  %-8s %s\n" "path:" "${dir/#${HOME}/\~}"

  if _link_fetch "${dir}" >/dev/null 2>&1; then
    local head target behind
    head="$(_link_head_commit "${dir}")"
    target="$(_link_target_commit "${dir}" "${ref}")"
    if [[ -n "${target}" && "${head}" != "${target}" ]]; then
      behind="$(git -C "${dir}" rev-list --count "${head}..${target}" 2>/dev/null || echo '?')"
      echo "  status:  $(c_warn "${behind} commit(s) behind '${ref}'") — run 'sandbox link sync'."
    else
      echo "  status:  $(c_ok "up to date") with '${ref}'."
    fi
  else
    echo "  status:  $(c_warn "could not fetch") — offline or credentials unavailable."
  fi
}

# _link_sync — advance the pinned commit to the ref's current tip (or a new
# --ref). Deliberate, reviewed, and shape-validated; refuses on local edits.
_link_sync() {
  local opt_ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)  usage_link ;;
      --ref)      opt_ref="${2:?--ref requires a value}"; shift ;;
      --ref=*)    opt_ref="${1#--ref=}" ;;
      -*)         die "Unknown option for 'link sync': $1" ;;
      *)          die "Unexpected argument: $1" ;;
    esac
    shift
  done
  link_is_active || die "No linked overlay to sync. Link one with: sandbox link <GIT-URL>"
  _link_require_git

  local dir; dir="$(link_active_dir)"
  [[ -n "${dir}" ]] || die "Linked overlay directory is missing or not a git clone; re-run 'sandbox link <GIT-URL>'."

  if _link_worktree_dirty "${dir}"; then
    die "Linked overlay has local uncommitted changes at ${dir/#${HOME}/\~}; refusing to overwrite them. Commit, stash, or discard them first."
  fi

  local ref; ref="${opt_ref:-$(link_ref_config)}"
  [[ -n "${ref}" ]] || die "No ref recorded for the link; pass --ref <TAG|BRANCH|COMMIT>."

  echo "==> Fetching"
  _link_fetch "${dir}" >/dev/null 2>&1 || die "git fetch failed (offline or credentials unavailable)."

  local old target
  old="$(_link_head_commit "${dir}")"
  target="$(_link_target_commit "${dir}" "${ref}")"
  [[ -n "${target}" ]] || die "ref '${ref}' did not resolve to a commit after fetch."

  if [[ "${old}" == "${target}" ]]; then
    # Still re-pin the ref/commit in case only --ref changed to an equal tip.
    link_write_config "${dir}" "$(link_url_config)" "${ref}" "${target}"
    echo "Already up to date with '${ref}' (${target:0:12})."
    return 0
  fi

  echo "==> Changes from ${old:0:12} to ${target:0:12} (${ref}):"
  git -C "${dir}" --no-pager diff --stat "${old}" "${target}" 2>/dev/null || true

  # Apply, then validate; roll back to the previous commit if the new tree
  # fails the shape gate so a bad ref can never become the active overlay.
  git -C "${dir}" checkout --quiet "${ref}" 2>/dev/null || true
  if ! git -C "${dir}" reset --hard --quiet "${target}"; then
    git -C "${dir}" reset --hard --quiet "${old}" 2>/dev/null || true
    die "Failed to advance the overlay to ${target:0:12}; left at ${old:0:12}."
  fi

  echo "==> Validating overlay shape"
  if ! link_validate_shape "${dir}"; then
    git -C "${dir}" reset --hard --quiet "${old}" 2>/dev/null || true
    die "New overlay tree (${ref} @ ${target:0:12}) failed validation; rolled back to ${old:0:12}."
  fi

  link_write_config "${dir}" "$(link_url_config)" "${ref}" "${target}"
  : > "$(_link_fetch_stamp "${dir}")" 2>/dev/null || true
  echo "Updated overlay to '${ref}' (${target:0:12})."
}

# _link_unlink — clear the link pointer, optionally keeping the clone.
_link_unlink() {
  local opt_keep="false" opt_yes="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)     usage_link ;;
      --keep-clone)  opt_keep="true" ;;
      --yes|-y)      opt_yes="true" ;;
      -*)            die "Unknown option for 'link unlink': $1" ;;
      *)             die "Unexpected argument: $1" ;;
    esac
    shift
  done
  link_is_active || { echo "No linked overlay to remove."; return 0; }

  local dir; dir="$(link_active_dir)"
  if [[ "${opt_yes}" != "true" ]]; then
    printf "Unlink overlay '%s'%s? [y/N] " "$(link_url_config)" \
      "$([[ "${opt_keep}" == "true" ]] && echo "" || echo " and delete its clone")"
    local reply; read -r reply
    case "${reply}" in y|Y|yes|YES) ;; *) echo "Aborted."; return 0 ;; esac
  fi

  link_clear_config "${dir}"
  if [[ "${opt_keep}" != "true" ]] && [[ -n "${dir}" ]] && [[ -d "${dir}" ]]; then
    rm -rf "${dir}"
    echo "Removed clone ${dir/#${HOME}/\~}."
  fi
  echo "Unlinked. The 'overlay:'/link keys were cleared from ${USER_SANDBOX_CONFIG/#${HOME}/\~}."
}

cmd_link() {
  [[ $# -gt 0 ]] || usage_link
  case "$1" in
    --help|-h|help)  usage_link ;;
    status)          shift; _link_status "$@" ;;
    sync)            shift; _link_sync "$@" ;;
    unlink)          shift; _link_unlink "$@" ;;
    *)               _link_clone "$@" ;;   # first arg is the git URL
  esac
}

###############################################################################
# cmd_profile — create and manage launch profiles
###############################################################################
usage_profile() {
  cat <<EOF
sandbox profile — Create and manage launch profiles

USAGE:
  sandbox profile save [OPTIONS]
  sandbox profile list
  sandbox profile show <NAME>
  sandbox profile delete <NAME> [--yes]
  sandbox profile --help

A profile is a named bundle of launch settings stored at
~/.sandbox/profiles/<name>.yaml and used via 'sandbox run --profile <name>'.
It records a required tier plus OPTIONAL agent, default repo, and extra
allowed domains. 'save' only writes YAML — every value is re-validated at
'run' time (tier check, blocked-destinations check on domains), so a saved
profile can never widen what a session is allowed to do.

SAVE OPTIONS (mirror 'sandbox run'):
  --tier <1|2|3>            Required.
  --agent <claude|codex|opencode|copilot|grok>
                            OPTIONAL. If omitted, the profile pins no agent
                            and 'run --profile' falls back to its --agent flag
                            (default: claude).
  --repo <PATH>             Optional default repo (single — see NOTES).
  --allow-domain <DOMAIN>   Optional extra egress domain (repeatable). Each is
                            run through the blocked-destinations check now, so
                            a profile that 'run' would reject is never saved.
  --name <NAME>             Profile name → filename. If omitted, it's derived
                            from the repo basename and agent (e.g. the example
                            below yields 'stratum-codex'), or the agent alone,
                            or 'tier<N>' for a bare-tier profile.
  --force                   Overwrite an existing profile of the same name.
  --dry-run                 Print the YAML to stdout instead of writing it.

NOTES:
  - Profiles are written to ~/.sandbox/profiles/ only, never an overlay.
    Overlay profiles are team-shipped; 'list'/'show' can read them, but
    'save'/'delete' will not touch them.
  - A single --repo is supported (the schema's default_repo is one path).
    Multi-repo launches still work via 'run --repo ... --repo ...'.

EXAMPLES:
  sandbox profile save --tier 2 --agent codex --repo ~/git/public/stratum \\
      --name stratum-codex
  sandbox profile save --tier 2 --repo ~/git/public/stratum   # → 'stratum'
  sandbox profile list
  sandbox profile show stratum-codex
  sandbox run --profile stratum-codex
EOF
  exit 0
}

# _profile_save — generate ~/.sandbox/profiles/<name>.yaml from run-style flags.
_profile_save() {
  local opt_tier="" opt_agent="" opt_name="" opt_force="false" opt_dry_run="false"
  local -a opt_repos=() opt_allow_domains=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)         usage_profile ;;
      --tier)            opt_tier="${2:?--tier requires a value}"; shift ;;
      --tier=*)          opt_tier="${1#--tier=}" ;;
      --agent)           opt_agent="${2:?--agent requires a value}"; shift ;;
      --agent=*)         opt_agent="${1#--agent=}" ;;
      --repo)            opt_repos+=("${2:?--repo requires a value}"); shift ;;
      --repo=*)          opt_repos+=("${1#--repo=}") ;;
      --allow-domain)    opt_allow_domains+=("${2:?--allow-domain requires a value}"); shift ;;
      --allow-domain=*)  opt_allow_domains+=("${1#--allow-domain=}") ;;
      --name)            opt_name="${2:?--name requires a value}"; shift ;;
      --name=*)          opt_name="${1#--name=}" ;;
      --force)           opt_force="true" ;;
      --dry-run)         opt_dry_run="true" ;;
      -*)                die "Unknown option for 'profile save': $1. Run 'sandbox profile --help'." ;;
      *)                 die "Unexpected argument: $1. Run 'sandbox profile --help'." ;;
    esac
    shift
  done

  [[ -n "${opt_tier}" ]] || die "profile save: --tier is required."
  validate_tier "${opt_tier}"
  [[ -n "${opt_agent}" ]] && validate_agent "${opt_agent}"

  # The schema's default_repo is a single path; refuse multi-repo rather than
  # silently dropping all but the first.
  if [[ "${#opt_repos[@]}" -gt 1 ]]; then
    die "profile save: only one --repo is supported (the profile holds a single default_repo). Use 'run --repo ... --repo ...' for multi-repo launches."
  fi

  local repo=""
  if [[ "${#opt_repos[@]}" -eq 1 ]]; then
    repo="${opt_repos[0]/#\~/${HOME}}"
    [[ -d "${repo}" ]] || warn "repo path '${repo}' is not a directory here; saving anyway (it may live on another machine)."
  fi
  if [[ "${opt_tier}" != "1" ]] && [[ -z "${repo}" ]]; then
    warn "tier ${opt_tier} usually needs a repo; none set, so 'run --profile' will require --repo."
  fi

  # Reject any blocked domain now — don't persist a profile 'run' would refuse.
  # check_domain_not_blocked exits non-zero (inside the subshell) on a match.
  if [[ "${#opt_allow_domains[@]}" -gt 0 ]]; then
    local d
    for d in "${opt_allow_domains[@]}"; do
      ( check_domain_not_blocked "${d}" ) \
        || die "profile save: domain '${d}' is blocked; refusing to save a profile that 'run' would reject."
    done
  fi

  # Derive a name when --name is absent (the "I'm lazy" path).
  local name="${opt_name}"
  if [[ -z "${name}" ]]; then
    local repo_base=""
    [[ -n "${repo}" ]] && repo_base="$(basename "${repo}")"
    if   [[ -n "${repo_base}" ]] && [[ -n "${opt_agent}" ]]; then name="${repo_base}-${opt_agent}"
    elif [[ -n "${repo_base}" ]]; then                           name="${repo_base}"
    elif [[ -n "${opt_agent}" ]]; then                           name="${opt_agent}"
    else                                                         name="tier${opt_tier}"
    fi
  fi
  if ! is_valid_profile_name "${name}"; then
    die "profile save: invalid name '${name}'. Use letters, digits, '.', '_', '-'; no '/', no leading '.', and not a bare tier number (1|2|3)."
  fi

  local domains_str=""
  [[ "${#opt_allow_domains[@]}" -gt 0 ]] && domains_str="$(printf '%s\n' "${opt_allow_domains[@]}")"

  local yaml
  yaml="$(render_profile_yaml "${name}" "${opt_tier}" "${opt_agent}" "${repo}" <<<"${domains_str}")"

  if [[ "${opt_dry_run}" == "true" ]]; then
    echo "${yaml}"
    return 0
  fi

  local dir; dir="$(user_profiles_dir)"
  local path="${dir}/${name}.yaml"
  if [[ -e "${path}" ]] && [[ "${opt_force}" != "true" ]]; then
    die "profile '${name}' already exists at ${path/#${HOME}/\~}. Re-run with --force to overwrite."
  fi
  mkdir -p "${dir}"
  printf '%s\n' "${yaml}" > "${path}"
  chmod 0644 "${path}"
  echo "Saved profile '${name}' → ${path/#${HOME}/\~}"
  echo "Launch it with: sandbox run --profile ${name}"
}

# _profile_list — list user + (non-shadowed) overlay profiles.
_profile_list() {
  case "${1:-}" in --help|-h) usage_profile ;; "") ;; *) die "Unexpected argument: $1" ;; esac

  local user_dir; user_dir="$(user_profiles_dir)"
  local overlay;  overlay="$(resolve_overlay_path)"

  local -a rows=()
  local f name tier agent repo
  if [[ -d "${user_dir}" ]]; then
    for f in "${user_dir}"/*.yaml; do
      [[ -e "${f}" ]] || continue
      name="$(basename "${f}" .yaml)"
      tier="$(extract_yaml_scalar_from_file "${f}" tier)"
      agent="$(extract_yaml_scalar_from_file "${f}" agent)"
      repo="$(extract_yaml_scalar_from_file "${f}" default_repo)"
      rows+=("$(printf '%-24s  %-7s  %-4s  %-8s  %s' "${name}" "user" "${tier:--}" "${agent:--}" "${repo:--}")")
    done
  fi
  if [[ -n "${overlay}" ]] && [[ -d "${overlay}/profiles" ]]; then
    for f in "${overlay}/profiles"/*.yaml; do
      [[ -e "${f}" ]] || continue
      name="$(basename "${f}" .yaml)"
      [[ -f "${user_dir}/${name}.yaml" ]] && continue   # user copy wins; already listed
      tier="$(extract_yaml_scalar_from_file "${f}" tier)"
      agent="$(extract_yaml_scalar_from_file "${f}" agent)"
      repo="$(extract_yaml_scalar_from_file "${f}" default_repo)"
      rows+=("$(printf '%-24s  %-7s  %-4s  %-8s  %s' "${name}" "overlay" "${tier:--}" "${agent:--}" "${repo:--}")")
    done
  fi

  if [[ "${#rows[@]}" -eq 0 ]]; then
    echo "No profiles found in ${user_dir/#${HOME}/\~}/${overlay:+ or the overlay}."
    echo "Create one with: sandbox profile save --tier <N> [--agent <A>] [--repo <PATH>] [--name <NAME>]"
    return 0
  fi
  printf '%-24s  %-7s  %-4s  %-8s  %s\n' "NAME" "SOURCE" "TIER" "AGENT" "REPO"
  printf '%s\n' "${rows[@]}"
}

# _profile_show — print a profile's YAML (user dir first, then overlay).
_profile_show() {
  [[ $# -ge 1 ]] || die "Usage: sandbox profile show <NAME>"
  case "$1" in --help|-h) usage_profile ;; esac
  local name="$1" path
  if ! path="$(find_profile_path "${name}")"; then
    die "Profile '${name}' not found in ~/.sandbox/profiles/ or the overlay."
  fi
  echo "# ${path/#${HOME}/\~}"
  cat "${path}"
}

# _profile_delete — remove a user profile (never an overlay profile).
_profile_delete() {
  local opt_yes="false" name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_profile ;;
      --yes|-y)  opt_yes="true" ;;
      -*)        die "Unknown option for 'profile delete': $1" ;;
      *)         [[ -z "${name}" ]] || die "Unexpected argument: $1"; name="$1" ;;
    esac
    shift
  done
  [[ -n "${name}" ]] || die "Usage: sandbox profile delete <NAME> [--yes]"

  local user_dir; user_dir="$(user_profiles_dir)"
  local path="${user_dir}/${name}.yaml"
  if [[ ! -f "${path}" ]]; then
    local resolved
    if resolved="$(find_profile_path "${name}")"; then
      die "Profile '${name}' is an overlay profile (${resolved/#${HOME}/\~}); 'profile delete' only removes your own profiles under ${user_dir/#${HOME}/\~}/."
    fi
    die "Profile '${name}' not found in ${user_dir/#${HOME}/\~}/."
  fi
  if [[ "${opt_yes}" != "true" ]]; then
    printf "Delete profile '%s' (%s)? [y/N] " "${name}" "${path/#${HOME}/\~}"
    local reply; read -r reply
    case "${reply}" in y|Y|yes|YES) ;; *) echo "Aborted."; return 0 ;; esac
  fi
  rm -f "${path}"
  echo "Deleted profile '${name}'."
}

cmd_profile() {
  [[ $# -gt 0 ]] || usage_profile
  local sub="$1"; shift
  case "${sub}" in
    --help|-h|help)    usage_profile ;;
    save)              _profile_save "$@" ;;
    list|ls)           _profile_list "$@" ;;
    show|cat)          _profile_show "$@" ;;
    delete|rm|remove)  _profile_delete "$@" ;;
    *) die "Unknown 'profile' subcommand: ${sub}. Run 'sandbox profile --help'." ;;
  esac
}

###############################################################################
# cmd_setup_proxy_cert — find and stage a corporate TLS-intercept proxy's
# root CA so the image build (and the running agent pods) trust the
# resigned certs it presents on egress.
#
# Resolution order:
#   1. --from-wire <host>      Direct openssl s_client extraction.
#   2. host trust store        Linux: /usr/local/share/ca-certificates/* and
#                              the system bundle. macOS: System keychain.
#                              WSL2 with no Linux match: Windows Root store.
#
# Output path defaults to config/extra-ca-certs/proxy-ca.crt (or the value
# of --output). Re-running with the same vendor overwrites in place.
#
# This command does not modify the sandbox cluster — after it succeeds, the
# user runs `sandbox rebuild` (or first-time `sandbox setup`) to bake the
# cert into the image. We surface that hint at the end on success.
###############################################################################
cmd_setup_proxy_cert() {
  local from_wire=""
  local vendor=""
  local out_path="${SANDBOX_ROOT}/config/extra-ca-certs/proxy-ca.crt"
  local list_only="false"
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from-wire)
        shift
        [[ $# -gt 0 ]] || die "setup-proxy-cert: --from-wire needs a host argument"
        from_wire="$1"
        shift ;;
      --vendor)
        shift
        [[ $# -gt 0 ]] || die "setup-proxy-cert: --vendor needs a name"
        vendor="$1"
        shift ;;
      --output|-o)
        shift
        [[ $# -gt 0 ]] || die "setup-proxy-cert: --output needs a path"
        out_path="$1"
        shift ;;
      --list)
        list_only="true"
        shift ;;
      --force|-f)
        force="true"
        shift ;;
      --help|-h)
        cat <<'EOF'
Usage: sandbox setup-proxy-cert [options]

Auto-extract a corporate TLS-intercept proxy's root CA from the host's
trust store and stage it for the sandbox image build.

Options:
  --from-wire <host[:port]>  Skip the trust-store scan; instead open a TLS
                             connection to <host> and capture the proxy
                             chain on the wire. Defaults port to 443.
  --vendor <name>            Restrict trust-store matching to a specific
                             subject substring. Default tries common ones
                             (Zscaler, Netskope, Forcepoint, Cisco
                             Umbrella, Palo Alto/Prisma, Symantec/Blue
                             Coat, iboss, Menlo).
  --output <path>            Write the PEM here. Default:
                             config/extra-ca-certs/proxy-ca.crt
  --list                     Print what was found; don't write the file.
  --force                    Overwrite an existing output file without
                             prompting.

After this command succeeds, run `sandbox rebuild` to bake the cert into
the sandbox image. The same cert is then trusted by all derived agent
images and by anything the running agent does inside the pod.
EOF
        return 0 ;;
      *)
        die "setup-proxy-cert: unknown option '$1' (use --help)" ;;
    esac
  done

  require_command openssl "Install openssl via your package manager."

  local platform
  platform="$(detect_platform)"

  local tmp_pem
  tmp_pem="$(mktemp -t sandbox-proxy-ca.XXXXXX.pem)"
  # shellcheck disable=SC2064
  trap "rm -f '${tmp_pem}'" EXIT

  local vendor_re
  vendor_re="$(proxy_ca_vendor_regex "${vendor}")"

  local source_desc=""
  if [[ -n "${from_wire}" ]]; then
    echo "==> Extracting proxy chain from wire (${from_wire})..."
    if ! extract_proxy_cert_from_wire "${from_wire}" "${tmp_pem}"; then
      die "Could not extract a cert chain from ${from_wire}. Check the host is reachable."
    fi
    source_desc="wire: ${from_wire}"
  elif [[ "${platform}" == "macos" ]]; then
    echo "==> Searching macOS System keychain for proxy CA (vendors: ${vendor_re})..."
    if ! extract_proxy_cert_macos "${vendor_re}" "${tmp_pem}"; then
      die "No matching cert in /Library/Keychains/System.keychain. If your org's
MITM uses an unusual name, pass --vendor <substring>, or try
  sandbox setup-proxy-cert --from-wire deb.nodesource.com"
    fi
    source_desc="macOS System keychain"
  else
    # Linux (and WSL2 — try Linux store first, fall back to Windows store).
    echo "==> Searching Linux trust store for proxy CA (vendors: ${vendor_re})..."
    if extract_proxy_cert_linux "${vendor_re}" "${tmp_pem}"; then
      source_desc="Linux trust store"
    elif is_wsl; then
      echo "  Nothing matched inside the WSL distro. Trying Windows trust store via PowerShell..."
      if ! extract_proxy_cert_windows "${vendor_re}" "${tmp_pem}"; then
        die "No matching cert in either the WSL distro trust store or the Windows
LocalMachine\\Root store. Pass --vendor <substring> if your org uses a
non-standard name, or try
  sandbox setup-proxy-cert --from-wire deb.nodesource.com"
      fi
      source_desc="Windows LocalMachine\\Root (via PowerShell)"
    else
      die "No matching cert in the host trust store. Pass --vendor <substring>
if your org uses a non-standard name, or try
  sandbox setup-proxy-cert --from-wire deb.nodesource.com"
    fi
  fi

  echo "  Source: ${source_desc}"
  echo "  Cert(s) extracted:"
  describe_pems "${tmp_pem}"

  if [[ "${list_only}" == "true" ]]; then
    return 0
  fi

  if [[ -e "${out_path}" ]] && [[ "${force}" != "true" ]]; then
    if [[ ! -t 0 ]]; then
      die "${out_path} already exists and stdin is not a TTY. Re-run with --force to overwrite."
    fi
    printf "Overwrite %s? [y/N] " "${out_path}" >&2
    local reply=""
    read -r reply
    case "${reply}" in
      y|Y|yes|YES) ;;
      *) echo "Aborted; existing file untouched." >&2; return 1 ;;
    esac
  fi

  mkdir -p "$(dirname "${out_path}")"
  cp "${tmp_pem}" "${out_path}"
  echo "==> Wrote ${out_path}"
  echo "    Run 'sandbox rebuild' to bake this cert into the sandbox image."
}

###############################################################################
# cmd_version — print the embedded version identity (read from .version at
# startup; see the reader near the top). Pure formatter — no git, no recompute.
###############################################################################
cmd_version() {
  local mode="full"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --short)   mode="short"; shift ;;
      --json)    mode="json";  shift ;;
      -h|--help) echo "Usage: sandbox version [--short|--json]"; return 0 ;;
      *) die "Unknown flag for 'version': $1 (see 'sandbox version --help')" ;;
    esac
  done

  if [[ "${mode}" == "short" ]]; then
    echo "${SANDBOX_VERSION}"
    return 0
  fi

  if [[ "${mode}" == "json" ]]; then
    printf '{"version":"%s","commit":"%s","commitDate":"%s","buildDate":"%s","treeState":"%s","bash":"%s","root":"%s"}\n' \
      "${SANDBOX_VERSION}" "${SANDBOX_COMMIT}" "${SANDBOX_COMMIT_DATE}" \
      "${SANDBOX_BUILD_DATE}" "${SANDBOX_TREE_STATE}" \
      "${BASH_VERSION%%(*}" "${SANDBOX_ROOT}"
    return 0
  fi

  # Human-readable block. Provenance lines appear only when embedded (a fresh,
  # never-installed checkout has just the version line and reports "dev").
  echo "sandbox ${SANDBOX_VERSION}"
  [[ -n "${SANDBOX_COMMIT}" ]] && \
    echo "  commit:  ${SANDBOX_COMMIT}${SANDBOX_COMMIT_DATE:+ (${SANDBOX_COMMIT_DATE})}"
  [[ -n "${SANDBOX_BUILD_DATE}" ]] && \
    echo "  built:   ${SANDBOX_BUILD_DATE}${SANDBOX_TREE_STATE:+ (${SANDBOX_TREE_STATE})}"
  echo "  runtime: bash ${BASH_VERSION%%(*}"
  echo "  root:    ${SANDBOX_ROOT}"
}

###############################################################################
# Main dispatch
###############################################################################
main() {
  if [[ $# -eq 0 ]]; then
    usage
  fi

  local command="$1"
  shift

  case "${command}" in
    run)        cmd_run "$@" ;;
    resume)     cmd_resume "$@" ;;
    allow)      cmd_allow "$@" ;;
    list)       cmd_list "$@" ;;
    logs)       cmd_logs "$@" ;;
    flows)      cmd_flows "$@" ;;
    stop)       cmd_stop "$@" ;;
    cleanup)    cmd_cleanup "$@" ;;
    check)      cmd_check "$@" ;;
    status)     cmd_status "$@" ;;
    install)    cmd_setup "$@" ;;
    setup)      cmd_setup "$@" ;;
    uninstall)  cmd_uninstall "$@" ;;
    upgrade)    cmd_upgrade "$@" ;;
    onboard)    cmd_onboard "$@" ;;
    secret)     cmd_secret "$@" ;;
    mask)       cmd_mask "$@" ;;
    exceptions) cmd_exceptions "$@" ;;
    vet)        cmd_vet "$@" ;;
    profile)    cmd_profile "$@" ;;
    link)       cmd_link "$@" ;;
    configure-network) cmd_configure_network "$@" ;;
    setup-proxy-cert) cmd_setup_proxy_cert "$@" ;;
    rebuild)    cmd_rebuild "$@" ;;
    version)    cmd_version "$@" ;;
    --help|-h|help) usage ;;
    *) die "Unknown command: ${command}. Run 'sandbox --help' for usage." ;;
  esac
}

# Run main only when executed directly, not when sourced (e.g. by the test
# suite, which exercises the pure helpers like infra_version_line in isolation).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
