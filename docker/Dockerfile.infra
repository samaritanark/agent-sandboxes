# docker/Dockerfile.infra
# sandbox:*-infra — Infra tooling layer (for Tier 3 sessions)
# - Adds kubectl, helm, openstack CLI, ansible
# - Build args determine which agent base to extend
# - NO baked-in credentials, no tsh, no docker/podman CLI
#
# Usage:
#   docker build --build-arg BASE_IMAGE=sandbox:claude -t sandbox:claude-infra -f Dockerfile.infra .
#   docker build --build-arg BASE_IMAGE=sandbox:codex -t sandbox:codex-infra -f Dockerfile.infra .
#   docker build --build-arg BASE_IMAGE=sandbox:opencode -t sandbox:opencode-infra -f Dockerfile.infra .

ARG BASE_IMAGE=sandbox:base
FROM ${BASE_IMAGE}

# Switch to root for package installation, then back to agent
USER root

# These tools track the current upstream release so image rebuilds pick up new
# versions without code changes — clusters and clouds move faster than this
# image does, and a kubectl pinned a few minors behind the server skews badly.
# Each tool keeps a build-arg escape hatch: pass --build-arg <TOOL>_VERSION=x.y.z
# to pin a specific version for reproducibility.

# --- kubectl ---
# stable.txt returns the latest stable release (e.g. v1.36.2).
ARG KUBECTL_VERSION=
RUN arch="$(dpkg --print-architecture)" \
  && version="${KUBECTL_VERSION:-$(curl -fsSL https://dl.k8s.io/release/stable.txt)}" \
  && version="${version#v}" \
  && curl -fsSL \
      "https://dl.k8s.io/release/v${version}/bin/linux/${arch}/kubectl" \
      -o /usr/local/bin/kubectl \
  && chmod +x /usr/local/bin/kubectl \
  && kubectl version --client

# --- helm ---
# Pinned to the latest 3.x rather than tracking latest: helm-latest-version now
# returns the 4.x line, and Helm 4 carries breaking changes. Most consumers
# won't move to Helm 4 until ArgoCD does. Bump this within 3.x, or override with
# --build-arg HELM_VERSION=x.y.z, once that lands.
ARG HELM_VERSION=3.21.1
RUN arch="$(dpkg --print-architecture)" \
  && version="${HELM_VERSION#v}" \
  && curl -fsSL \
      "https://get.helm.sh/helm-v${version}-linux-${arch}.tar.gz" \
    | tar -xz -C /usr/local/bin --strip-components=1 "linux-${arch}/helm" \
  && chmod +x /usr/local/bin/helm \
  && helm version

# --- OpenStack CLI ---
# --break-system-packages opts out of Ubuntu 24.04's PEP 668 guard, which
# blocks bare pip installs into the externally-managed system Python.
ARG OPENSTACKCLIENT_VERSION=
RUN pip3 install --no-cache-dir --break-system-packages \
    "python-openstackclient${OPENSTACKCLIENT_VERSION:+==${OPENSTACKCLIENT_VERSION}}" \
  && openstack --version

# --- Ansible ---
ARG ANSIBLE_VERSION=
RUN pip3 install --no-cache-dir --break-system-packages \
    "ansible${ANSIBLE_VERSION:+==${ANSIBLE_VERSION}}" \
  && ansible --version

# Verify they are NOT present
RUN ! command -v tsh > /dev/null 2>&1 \
  && ! command -v docker > /dev/null 2>&1 \
  && ! command -v podman > /dev/null 2>&1 \
  && echo "Infra image security checks passed."

# Return to non-root user
USER agent

# ENTRYPOINT is inherited from base agent image
